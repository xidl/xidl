interface HelloWorld {
    @post(path = "/hello")
    void sayHello(
        in string name
    );

};

enum EnumFirstDefault {
    First
};

enum EnumSecondDefault {
    First,
    @default_literal
    Second
};

struct SimpleStruct {
    uint8 a;
};

struct ComplexStruct {
    uint8 a;
    SimpleStruct b;
    EnumFirstDefault c;
    EnumSecondDefault d;
};
