#pragma xidlc service http://127.0.0.1:8080 dev server

interface HelloWorld {
    @post(path = "/hello")
    void sayHello(
        in string name
    );

    sequence<ComplexStruct> getComplexStructs();

};

enum EnumFirstDefault {
    First
};

enum EnumSecondDefault {
    First,
    @default_literal
    Second
};

struct SimpleStruct {
    uint8 a;
};

struct ComplexStruct {
    uint8 a;
    SimpleStruct b;
    EnumFirstDefault c;
    EnumSecondDefault d;
};
