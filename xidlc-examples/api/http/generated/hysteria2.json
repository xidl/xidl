{
  "openapi": "3.1.0",
  "info": {
    "title": "xidl",
    "version": "0.1.0"
  },
  "paths": {
    "/auth": {
      "post": {
        "operationId": "Hysteria2.auth",
        "parameters": [
          {
            "name": "Hysteria-Auth",
            "in": "header",
            "description": "Authentication credentials.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Hysteria-CC-RX",
            "in": "header",
            "description": "Client's maximum receive rate in bytes per second. A value of 0 indicates unknown.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "Hysteria-Padding",
            "in": "header",
            "description": "A random padding string of variable length.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "udp",
                    "rx",
                    "padding"
                  ],
                  "properties": {
                    "padding": {
                      "type": "string"
                    },
                    "rx": {
                      "type": "integer",
                      "format": "int32",
                      "minimum": 0
                    },
                    "udp": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "properties": {
          "code": {
            "type": "integer"
          },
          "details": {
            "type": "object"
          },
          "msg": {
            "type": "string"
          }
        }
      },
      "Hysteria2_Call": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "unknownOp"
            ],
            "properties": {
              "unknownOp": {
                "$ref": "#/components/schemas/dds.rpc.UnknownOperation"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "auth"
            ],
            "properties": {
              "auth": {
                "$ref": "#/components/schemas/Hysteria2_auth_In"
              }
            }
          }
        ]
      },
      "Hysteria2_Reply": {
        "type": "object",
        "required": [
          "header",
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Hysteria2_Return"
          },
          "header": {
            "$ref": "#/components/schemas/dds.rpc.ReplyHeader"
          }
        }
      },
      "Hysteria2_Request": {
        "type": "object",
        "required": [
          "header",
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Hysteria2_Call"
          },
          "header": {
            "$ref": "#/components/schemas/dds.rpc.RequestHeader"
          }
        }
      },
      "Hysteria2_Return": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "unknownOp"
            ],
            "properties": {
              "unknownOp": {
                "$ref": "#/components/schemas/dds.rpc.UnknownOperation"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "auth"
            ],
            "properties": {
              "auth": {
                "$ref": "#/components/schemas/Hysteria2_auth_Result"
              }
            }
          }
        ]
      },
      "Hysteria2_auth_In": {
        "type": "object",
        "required": [
          "auth",
          "rx",
          "padding"
        ],
        "properties": {
          "auth": {
            "type": "string"
          },
          "padding": {
            "type": "string"
          },
          "rx": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "Hysteria2_auth_Out": {
        "type": "object",
        "required": [
          "udp",
          "rx",
          "padding"
        ],
        "properties": {
          "padding": {
            "type": "string"
          },
          "rx": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "udp": {
            "type": "boolean"
          }
        }
      },
      "Hysteria2_auth_Result": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "result"
            ],
            "properties": {
              "result": {
                "$ref": "#/components/schemas/Hysteria2_auth_Out"
              }
            }
          }
        ]
      }
    }
  }
