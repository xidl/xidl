{
  "openapi": "3.1.0",
  "info": {
    "title": "xidl",
    "version": "0.1.0"
  },
  "paths": {
    "/upgrade/echo": {
      "get": {
        "operationId": "HttpUpgradeService.connect_echo",
        "responses": {
          "204": {
            "description": "OK"
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/upgrade/raw": {
      "get": {
        "operationId": "HttpUpgradeService.connect_raw",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "OK"
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/upgrade/secure": {
      "get": {
        "operationId": "HttpUpgradeService.connect_secure",
        "parameters": [
          {
            "name": "X-Secure-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "OK"
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "properties": {
          "code": {
            "type": "integer"
          },
          "details": {
            "type": "object"
          },
          "msg": {
            "type": "string"
          }
        }
      }
    }
  }
}