{
  "openapi": "3.1.0",
  "info": {
    "title": "xidl",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080",
      "description": "dev server"
    }
  ],
  "paths": {
    "/getComplexStructs": {
      "post": {
        "operationId": "HelloWorld.getComplexStructs",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ComplexStruct"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/hello": {
      "post": {
        "operationId": "HelloWorld.sayHello",
        "requestBody": {
          "content": {
            "text/plain": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "OK"
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ComplexStruct": {
        "type": "object",
        "required": [
          "a",
          "b",
          "c",
          "d"
        ],
        "properties": {
          "a": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "b": {
            "$ref": "#/components/schemas/SimpleStruct"
          },
          "c": {
            "$ref": "#/components/schemas/EnumFirstDefault"
          },
          "d": {
            "$ref": "#/components/schemas/EnumSecondDefault"
          }
        }
      },
      "EnumFirstDefault": {
        "type": "string",
        "enum": [
          "First"
        ]
      },
      "EnumSecondDefault": {
        "type": "string",
        "enum": [
          "First",
          "Second"
        ]
      },
      "Error": {
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "properties": {
          "code": {
            "type": "integer"
          },
          "details": {
            "type": "object"
          },
          "msg": {
            "type": "string"
          }
        }
      },
      "SimpleStruct": {
        "type": "object",
        "required": [
          "a"
        ],
        "properties": {
          "a": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      }
    }
  }
}