{
  "openapi": "3.1.0",
  "info": {
    "title": "xidlc examples",
    "version": "v1.0.0"
  },
  "paths": {
    "/v1/forms/profile": {
      "post": {
        "operationId": "RestMediaTypesApi.submit_profile",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "age"
                ],
                "properties": {
                  "age": {
                    "type": "integer",
                    "format": "int32",
                    "minimum": 0
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "return",
                    "normalized_name"
                  ],
                  "properties": {
                    "normalized_name": {
                      "type": "string"
                    },
                    "return": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/msgpack/users/{user_id}": {
      "get": {
        "operationId": "RestMediaTypesApi.get_msgpack_user",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/msgpack": {
                "schema": {
                  "type": "object",
                  "required": [
                    "return",
                    "score"
                  ],
                  "properties": {
                    "return": {
                      "type": "string"
                    },
                    "score": {
                      "type": "integer",
                      "format": "int32",
                      "minimum": 0
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "properties": {
          "code": {
            "type": "integer"
          },
          "details": {
            "type": "object"
          },
          "msg": {
            "type": "string"
          }
        }
      }
    }
  }
}