@http-basic
interface CityHttpStreamApi {
  @server-stream
  @stream-codec("sse")
  @path("/alerts/{district}{?lang}")
  string alerts(
    @path("district") string district,
    @query("lang") string lang
  );

  @no-security
  @server-stream
  @stream-codec("sse")
  @path("/ticker")
  string ticker();

  attribute boolean maintenance_mode;

  @client-stream
  @stream-codec("ndjson")
  @http-bearer
  @path("/assets/upload")
  string upload_asset(
    in string asset_id,
    in sequence<octet> chunk
  );

  @bidi-stream
  @path("/chat")
  void chat(
    in string room,
    in string message,
    out string from,
    out string text
  );
};
