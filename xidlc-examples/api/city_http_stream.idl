interface CityHttpStreamApi {
  @server_stream
  @stream_codec("sse")
  @path("/alerts/{district}{?lang}")
  string alerts(
    @path("district") string district,
    @query("lang") string lang
  );

  @server_stream
  @stream_codec("sse")
  @path("/ticker")
  string ticker();

  attribute boolean maintenance_mode;

  @client_stream
  @stream_codec("ndjson")
  @path("/assets/upload")
  string upload_asset(
    in string asset_id,
    in sequence<octet> chunk
  );

  @bidi_stream
  @path("/chat")
  void chat(
    in string room,
    in string message,
    out string from,
    out string text
  );
};
