{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "exclude-paths": ["./website"],
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "component": "xidl",
      "extra-files": [
        {
          "jsonpath": "$.dependencies.xidlc.version",
          "path": "xidl-build/Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.package.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.dependencies.xidl-parser.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.dependencies.xidl-parser-derive.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.dependencies.xidl-jsonrpc.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.dependencies.xidl-rust-axum.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.dependencies.xidl-build.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.workspace.dependencies.xidlc.version",
          "path": "Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.dependencies.xidl-jsonrpc.version",
          "path": "xidlc/Cargo.toml",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-build')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-parser-derive')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-jsonrpc')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-rust-axum')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidlc')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-parser')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-typeobject')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-api-keycloak')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-api-discord')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-api-reddit')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.package[?(@.name.value=='xidl-api-github')].version",
          "path": "Cargo.lock",
          "type": "toml"
        },
        {
          "jsonpath": "$.version",
          "path": "typescript/xidl-typescript-codec/package.json",
          "type": "json"
        },
        {
          "jsonpath": "$.version",
          "path": "typescript/xidl-typescript-codec/jsr.json",
          "type": "json"
        }
      ],
      "release-type": "simple"
    },
    "golang/xidl-go": {
      "component": "golang/xidl-go",
      "include-component-in-tag": true,
      "release-type": "simple",
      "tag-separator": "/"
    },
    "golang/xidl-go-codec": {
      "component": "golang/xidl-go-codec",
      "include-component-in-tag": true,
      "release-type": "simple",
      "tag-separator": "/"
    },
    "golang/xidl-go-rest": {
      "component": "golang/xidl-go-rest",
      "include-component-in-tag": true,
      "release-type": "simple",
      "tag-separator": "/"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "xidl",
      "components": [
        "xidl",
        "golang/xidl-go",
        "golang/xidl-go-codec",
        "golang/xidl-go-rest"
      ]
    }
  ]
}
