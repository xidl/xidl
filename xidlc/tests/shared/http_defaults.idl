#pragma xidlc package xidlc
#pragma xidlc version v1.0.0

@derive(Debug, Serialize, Deserialize)
struct CreateUserRequest {
    string name;
    uint32 age;
};

interface HttpDefaultsService {
    // default verb POST, explicit query source
    string get_name(
        @query
        string name
    );
    // default source for GET parameters -> query, except explicit path
    @get
    string list_orders(
        @path("uid")
        uint32 user_id,
        uint32 page,
        uint32 size
    );
    // single body parameter -> encode as object keyed by parameter name
    @post(path = "/users")
    string create_user(
        CreateUserRequest req
    );
    // single body parameter with flatten -> encode object directly
    @post(path = "/users/flat")
    string create_user_flat(
        @flatten
        CreateUserRequest req
    );
    // multiple body parameters -> encode as object by parameter names
    @post(path = "/users/search")
    string search_user(
        string name,
        uint32 age
    );
    // explicit body source on GET
    @get(path = "/users/preview")
    string preview_user(
        @body("user")
        CreateUserRequest req
    );
    // route template source inference
    @get(path = "/v1/users/{id}")
    string get_user(
        uint32 id,
        @query
        string lang
    );
    // explicit bound names
    string get_user_alias(
        @path("id")
        uint32 user_id,
        @query("lang")
        string locale
    );
};
