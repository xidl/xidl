#pragma xidlc package xidlc
#pragma xidlc version v1.0.0

struct ProjectEvent {
    string id;
    string payload;
};

interface HttpStreamSseBindingsService {
    @server_stream
    @stream_codec("sse")
    @get(path = "/projects/{project_id}/events{?cursor}")
    ProjectEvent watch_project(
        @path @rename("project_id")
        string project_id,
        @query @rename("cursor")
        @optional
        string cursor,
        @header @rename("X-Trace-Id")
        string trace_id
    );
};
