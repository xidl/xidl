
enum Tag {
    V1,
    V2,
    V3,
};


union UnionValue switch (Tag) {
    case Tag::V1:
        int case1;
    case Tag::V2:
        sequence<string> case2;
    case Tag::V3:
        map<string, string> case3;
};


union IntTagValue switch (long) {
    case 1:
        string one;
    case 2:
    case 3:
        int two_or_three;
    default:
        boolean fallback;
};


union BoolTagValue switch (boolean) {
    case TRUE:
        string yes;
    case FALSE:
        string no;
};


union CharTagValue switch (char) {
    case 'x':
        string ex;
    case 'y':
        string why;
    default:
        string other;
};
