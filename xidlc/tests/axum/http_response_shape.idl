#progma xidlc package xidlc
#progma xidlc version v1.0.0

interface HttpResponseShapeService {
    // output count = 1 (return only) -> direct value
    string hello();

    // output count = 1 (out only) -> direct value
    void get_count(
        out long count
    );

    // output count > 1 -> object { return, ...outFields }
    long add(
        in long a,
        in long b,
        out long sum
    );

    // inout participates in input and output sets
    long bump(
        inout long value
    );

    // output count = 0 -> 204 no body
    void ping();
};
