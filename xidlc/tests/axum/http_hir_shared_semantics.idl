@http_bearer
interface ReportApi {
  @get(path = "/reports/{id}{?lang}")
  string get_report(
    @path("id") string id,
    @query("lang") @optional string lang,
    @header("X-Trace-Id") string trace_id
  );

  @server_stream
  @get(path = "/reports/{id}/events")
  string watch_report(@path("id") string id);
};
