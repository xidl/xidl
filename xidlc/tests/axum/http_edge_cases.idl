#progma xidlc package xidlc
#progma xidlc version v1.0.0

interface HttpEdgeCasesService {
    // HEAD keeps request-side path/query parameters and always has no response body.
    @head(path = " //v1//health/ ")
    void health(
        @query("trace_id") string trace
    );

    // Multi-route + normalized paths + explicit @path binding.
    @get(path = "//v1//users/{id}//")
    @path("/v2/users/{id}/")
    string get_user(
        @path("id") uint32 uid,
        @query("lang") string locale
    );

    // Path source inferred from route template variables.
    @get(path = "/orders/{order_id}/items/{item_id}")
    string get_item(
        uint32 order_id,
        uint32 item_id
    );

    // Default route is based on method name only; query does not affect path.
    string lookup(
        @query string keyword,
        @query("limit") uint32 page_size
    );
};
