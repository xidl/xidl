#pragma xidlc package xidlc
#pragma xidlc version v1.0.0

interface HttpStreamSseBindingsService {
    @server_stream
    @stream_codec("sse")
    @get(path = "/files/{*path}{?lang,follow}")
    sequence<string> tail_file(
        @path @rename("path")
        string path,
        @query @rename("lang")
        string lang,
        @query @rename("follow")
        boolean follow
    );
};
