#pragma xidlc package xidlc tests go

interface RestMediaTypesApi {
    @post(path = "/v1/forms/profile")
    @Consumes("application/x-www-form-urlencoded")
    string submit_profile(
        string name,
        uint32 age,
        out string normalized_name
    );
    @get(path = "/v1/msgpack/users/{user_id}")
    @Produces("application/msgpack")
    string get_msgpack_user(
        @path @rename("user_id")
        string user_id,
        out uint32 score
    );
};
