#![allow(unused_imports)]
#![allow(non_upper_case_globals)]
#![allow(non_snake_case)]
#![allow(unused_variables)]
#![allow(unreachable_patterns)]
#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
pub enum Tag {
    #[default]
    A,
    B,
}
pub struct DefaultUnion {
    tag: Tag,
    data: DefaultUnionData,
}
union DefaultUnionData {
    a: core::mem::ManuallyDrop<int>,
    fallback: core::mem::ManuallyDrop<String>,
}
impl Drop for DefaultUnion {
    fn drop(&mut self) {
        match self.tag {
            A => {
                unsafe {
                    core::mem::ManuallyDrop::drop(&mut self.data.a);
                }
            }
            _ => {
                unsafe {
                    core::mem::ManuallyDrop::drop(&mut self.data.fallback);
                }
            }
        }
    }
}
impl DefaultUnion {
    pub fn new_a(value: int) -> Self {
        Self {
            tag: A,
            data: DefaultUnionData {
                a: core::mem::ManuallyDrop::new(value),
            },
        }
    }
    pub fn is_a(&self) -> bool {
        matches!(self.tag, A)
    }
    pub fn as_a(&self) -> &int {
        debug_assert!(self.is_a());
        unsafe { &self.data.a }
    }
    pub fn as_a_mut(&mut self) -> &mut int {
        debug_assert!(self.is_a());
        unsafe { &mut self.data.a }
    }
    pub fn into_a(self) -> int {
        debug_assert!(self.is_a());
        unsafe {
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.a)
        }
    }
    pub fn new_fallback(value: String) -> Self {
        Self {
            tag: Tag::default(),
            data: DefaultUnionData {
                fallback: core::mem::ManuallyDrop::new(value),
            },
        }
    }
    pub fn is_fallback(&self) -> bool {
        matches!(self.tag, _)
    }
    pub fn as_fallback(&self) -> &String {
        debug_assert!(self.is_fallback());
        unsafe { &self.data.fallback }
    }
    pub fn as_fallback_mut(&mut self) -> &mut String {
        debug_assert!(self.is_fallback());
        unsafe { &mut self.data.fallback }
    }
    pub fn into_fallback(self) -> String {
        debug_assert!(self.is_fallback());
        unsafe {
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.fallback)
        }
    }
    pub fn tag(&self) -> &Tag {
        &self.tag
    }
}
impl Default for DefaultUnion {
    fn default() -> Self {
        Self {
            tag: Tag::default(),
            data: DefaultUnionData {
                fallback: core::mem::ManuallyDrop::new(String::default()),
            },
        }
    }
