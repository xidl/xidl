impl HttpBidiStreamServiceClient{
    pub async fn chat(&self,room:String,text:String)->Result<xidl_rust_axum::stream::ReaderWriter<HttpBidiStreamServiceChatRequest,HttpBidiStreamServiceChatResponse>,xidl_rust_axum::Error>{
        let path = "/chat".to_string();
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,&self.client.url(&path))
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        let auth_target = &self.client;
        let mut ws_url = self.client.ws_url(&path)?;
        return xidl_rust_axum::stream::open_bidi_client::<HttpBidiStreamServiceChatRequest,HttpBidiStreamServiceChatResponse>(&ws_url).await;
    }
}
