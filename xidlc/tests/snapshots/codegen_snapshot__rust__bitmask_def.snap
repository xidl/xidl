pub struct EmptyBitmask {
    pub value: u32,
}
impl EmptyBitmask {}
pub struct SimpleBitmask {
    pub value: u32,
}
impl SimpleBitmask {
    pub const A: u32 = 1u32 << 0;
    pub const B: u32 = 1u32 << 1;
    pub const C: u32 = 1u32 << 2;
}
pub struct PositionedBitmask {
    pub value: u32,
}
impl PositionedBitmask {
    pub const A: u32 = 1u32 << 0;
    pub const B: u32 = 1u32 << 2;
    pub const C: u32 = 1u32 << 4;
