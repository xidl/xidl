    B
}

pub struct BM{
    pub value:u32,
}

impl BM{
    pub const A:u32 = 1u32<<0;
    pub const B:u32 = 1u32<<1;
}

impl xidl_xcdr::XcdrSerialize for BM{
    fn serialize_with<S:xidl_xcdr::XcdrSerializer+?Sized>(
    &self,
    serializer:&mut S,
    )->xidl_xcdr::error::XcdrResult<()>{
        xidl_xcdr::XcdrSerialize::serialize_with(&self.value,serializer)
    }
}

impl xidl_xcdr::XcdrDeserialize for BM{
    fn deserialize<D:xidl_xcdr::XcdrDeserializer+?Sized>(
    deserializer:&mut D,
    )->xidl_xcdr::error::XcdrResult<Self>{
        let value = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;
        Ok(Self{
            value})
    }
}

pub struct U{
    tag:i32,
    data:UData,
}

union UData{
    a:core::mem::ManuallyDrop<i32>,
    b:core::mem::ManuallyDrop<i32>,
}

impl Drop for U{
    fn drop(&mut self){
        match self.tag{
            0 => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.a);
                }
            }
            _ => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.b);
                }
            }
        }
    }
}

impl U{
    pub fn new_a(value:i32)->Self{
        Self{
            tag:0,
            data:UData{
                a:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_a(&self)->bool{
        matches!(self.tag,0)
    }

    pub fn as_a(&self)->&i32{
        debug_assert!(self.is_a());
        unsafe{
            &self.data.a
        }
    }

    pub fn as_a_mut(&mut self)->&mut i32{
        debug_assert!(self.is_a());
        unsafe{
            &mut self.data.a
        }
    }

    pub fn into_a(self)->i32{
        debug_assert!(self.is_a());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.a)
        }
    }

    pub fn new_b(value:i32)->Self{
        Self{
            tag:i32::default(),
            data:UData{
                b:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_b(&self)->bool{
        matches!(self.tag,_)
    }

    pub fn as_b(&self)->&i32{
        debug_assert!(self.is_b());
        unsafe{
            &self.data.b
        }
    }

    pub fn as_b_mut(&mut self)->&mut i32{
        debug_assert!(self.is_b());
        unsafe{
            &mut self.data.b
        }
    }

    pub fn into_b(self)->i32{
        debug_assert!(self.is_b());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.b)
        }
    }

    pub fn tag(&self)->&i32{
        &self.tag
    }
}
