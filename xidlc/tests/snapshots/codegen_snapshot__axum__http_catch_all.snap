pub struct HttpCatchAllServiceClient{
    client:xidl_rust_axum::Client,
}

impl HttpCatchAllServiceClient{
    pub fn new(base_url:impl Into<String>)->Self{
        Self{
            client:xidl_rust_axum::Client::new(base_url),
        }
    }
}

impl HttpCatchAllServiceClient{
    pub async fn read_file(&self,rel_path:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/files/{*path}".to_string();
        let path = path.replace("{*path}",&rel_path.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }

    pub async fn read_asset(&self,key:String,version:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/assets/{*key}".to_string();
        let path = path.replace("{*key}",&key.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let query = HttpCatchAllServiceReadAssetQuery{
            version,
        };
        let query = xidl_rust_axum::serde_urlencoded::to_string(&query)
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if!query.is_empty(){
            req.url_mut().set_query(Some(&query));
        }

        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }
}
