export class HttpCatchAllServiceClient{
    private readonly baseUrl : string;
    private readonly fetchImpl : FetchLike;
    private readonly defaultHeaders : Record<
    string, string
    >;
    constructor(
    baseUrl : string, options : ClientOptions = {
    }
    ){
        this.baseUrl = baseUrl;
        this.fetchImpl = resolveFetch(
        options.fetch
        );
        this.defaultHeaders = options.headers??{
        };
    }

    async read_file(
    rel_path : string
    ) : Promise<
    string
    >{
        const parsed = zodSchemas.HttpCatchAllServiceReadFileRequestSchema.parse(
        {
            "rel_path" : rel_path
        }
        );
        let path = "/files/{*path}";
        path = path.replace(
        "{"+"*path"+"}", encodePathCatchAll(
        parsed["rel_path"]
        )
        );
        const headers = {
            ...this.defaultHeaders
        };
        const options = {
            method : "GET", headers
        };
        const url = joinUrl(
        this.baseUrl, path
        );
        const resp = await this.fetchImpl(
        url, options
        );
        if(!resp.ok){
            throw await parseXidlError(
            resp
            );
        }
        const data = await resp.json(

        );
        return data as string;
    }

    async read_asset(
    key : string, version : string
    ) : Promise<
    string
    >{
        const parsed = zodSchemas.HttpCatchAllServiceReadAssetRequestSchema.parse(
        {
            "key" : key, "version" : version
        }
        );
        let path = "/assets/{*key}";
        path = path.replace(
        "{"+"*key"+"}", encodePathCatchAll(
        parsed["key"]
        )
        );
        const query = new URLSearchParams(

        );
        query.set(
        "v", encodeQueryValue(
        parsed["version"]
        )
        );
        const queryString = query.toString(

        );
        if(queryString.length>0){
            path = `${path}?${queryString}`;
        }

        const headers = {
            ...this.defaultHeaders
        };
        const options = {
            method : "GET", headers
        };
        const url = joinUrl(
        this.baseUrl, path
        );
        const resp = await this.fetchImpl(
        url, options
        );
        if(!resp.ok){
            throw await parseXidlError(
            resp
            );
        }
        const data = await resp.json(

        );
        return data as string;
    }
}
