    red, green, blue
};
template < > struct xidl::xcdr::Traits < Color > {
    template < typename Codec > static inline xidl::xcdr::BufferResult serialize(xidl::xcdr::Serializer < Codec > &ser, Color value){
        uint32_t raw = static_cast < uint32_t > (value);
        return ser.write(raw);
    }

    template < typename Codec > static inline xidl::xcdr::BufferResult deserialize(xidl::xcdr::Deserializer < Codec > &de, Color&value){
        uint32_t raw = 0;
        xidl::xcdr::BufferResult res = de.read(raw);
        if(res.ok()){
            value = static_cast < Color > (raw);
        }
        return res;
    }
};
