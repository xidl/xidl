struct A{
    enum _flags:uint32_t{
    };
    uint32_t _value{
        0
    };
    constexpr uint32_t operator()()const{
        return _value;
    }
    constexpr operator uint32_t()const{
        return _value;
    }
    constexpr A() = default;
    constexpr A(uint32_t v):_value(v){
    }
    A&operator|=(uint32_t other){
        _value|=other;
        return * this;
    }
    A&operator&=(uint32_t other){
        _value&=other;
        return * this;
    }
    A&operator^=(uint32_t other){
        _value^=other;
        return * this;
    }
};
template < > struct xidl::xcdr::Traits < A > {
    template < typename Codec > static inline xidl::xcdr::BufferResult serialize(xidl::xcdr::Serializer < Codec > &ser, const A&value){
        return ser.write(value._value);
    }

    template < typename Codec > static inline xidl::xcdr::BufferResult deserialize(xidl::xcdr::Deserializer < Codec > &de, A&value){
        uint32_t raw = 0;
        xidl::xcdr::BufferResult res = de.read(raw);
        if(res.ok()){
            value._value = raw;
        }
        return res;
    }
};
