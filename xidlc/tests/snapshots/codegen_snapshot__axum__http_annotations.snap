        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
        xidl_rust_axum::reqwest::header::HeaderValue::from_static("application/json"),
        );
        *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if resp.status().is_success(){
            resp.json::<HttpAnnoServiceBumpResponse>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }

    pub async fn get_count(&self)->Result<i32,xidl_rust_axum::Error>{
        let path = "/get_count".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if resp.status().is_success(){
            resp.json::<i32>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }

    pub async fn ping(&self)->Result<(),xidl_rust_axum::Error>{
        let path = "/ping".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if resp.status().is_success(){
            Ok(())
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }
