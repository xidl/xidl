        .route("/get_name",xidl_rust_axum::axum::routing::post(Self::get_name))

        .route("/search_user",xidl_rust_axum::axum::routing::get(Self::search_user))

        .route("/get_user_alias/{id}",xidl_rust_axum::axum::routing::post(Self::get_user_alias))

