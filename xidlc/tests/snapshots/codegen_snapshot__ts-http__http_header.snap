                return;
            }
            controller.enqueue(
            encoder.encode(
            `${JSON.stringify(
                next.value
                )}\n`
            )
            );

        },
    }
    );
}

export namespace test{
    export class HeaderServiceClient{
        private readonly baseUrl : string;
        private readonly fetchImpl : FetchLike;
        private readonly defaultHeaders : Record<
        string, string
        >;
        private readonly auth ? : ClientAuth;
        private readonly codecs : Record<
        string, HttpCodec
        >;
