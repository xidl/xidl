function encodeBody(
value : unknown, contentType : string, codecs : Record<
string, HttpCodec
>, schema ? : z.ZodTypeAny,
) : BodyInit | null{
    const mime = normalizeMime(
    contentType
    );
    const custom = codecs[mime]?.encode;
    if(custom){
        return custom(
        value, schema
        );
    }
    if(mime==="application/json"||mime.endsWith(
    "+json"
    )||mime==="application/msgpack"){
        const serialized = schema ?serialize(
        value, schema
        ) : value;
        return JSON.stringify(
        serialized
        );
    }

    if(mime.startsWith(
    "text/"
    )){
        return String(
        value??""
        );
    }
