    `unsupported response content type: ${mime}`, 500
    );
}

function normalizeMime(
value : string
) : string{
    return value.split(
    ";"
    )[0]?.trim(

    ).toLowerCase(

    )??"application/json";
}

function encodeScalar(
value : unknown
) : string{
    if(typeof value==="string"||typeof value==="number"||typeof value==="boolean"){
        return String(
        value
        );
    }
    return JSON.stringify(
    value
    );
}

function parseScalar(
value : string
) : unknown{
    if(value==="true"){
        return true;
    }
    if(value==="false"){
        return false;
    }
    if(/^-?\d+(\.\d+)?$/.test(
    value
    )){
        return Number(
        value
        );
    }
    try{
        return JSON.parse(
        value
        );

    }catch{
        return value;
    }
}

function errorResponse(
error : unknown
) : Response{
    if(error instanceof XidlServerError){
        const headers = new Headers(
        {
            "Content-Type" : "application/json"
        }
        );
        if(error.headers){
            for(const[key, value]of Object.entries(
            error.headers
            )){
                headers.set(
                key, value
                );
            }
        }
        return new Response(
        JSON.stringify(
        {
            code : error.code, msg : error.message
        }
        ), {
            status : error.status, headers,
        }
        );
    }
    if(error&&typeof error==="object"&&"name"in error&&error.name==="ZodError"){
        return new Response(
        JSON.stringify(
        {
            code : 400, msg : "validation failed", detail : (error as any).errors
        }
        ), {
            status : 400, headers : {
                "Content-Type" : "application/json"
            },
        }
        );
    }
    const message = error instanceof Error ?error.message : "internal server error";
    return new Response(
    JSON.stringify(
    {
        code : 500, msg : message
    }
    ), {
        status : 500, headers : {
            "Content-Type" : "application/json"
        },
    }
    );
}

export namespace test{
    export interface HeaderService{
        get_user(
        req : ifaceTypes.test.HeaderServiceGetUserRequest
        ) : Awaitable<
        types.User
        >;
        create_user(
        req : ifaceTypes.test.HeaderServiceCreateUserRequest
        ) : Awaitable<
        void
        >;
    }

    export function createHeaderServiceHandler(
    service : HeaderService, options : ServerOptions = {
    },
    ) : ServerHandler{
        return createRouter(
        [
        {
            method : "GET", path : "/v1/headers/{id}", handler : async(
            request, params
            ) => {
                const url = new URL(
                request.url
                );
                await authorizeRequest(
                request, [

                ], options
                );
                const rawPayload = {
                    "id" : readPathParam(
                    params, "id"
                    ), "req_id" : readHeaderParam(
                    request.headers, "X-Req-Id", false
                    ), "flags" : readHeaderParam(
                    request.headers, "X-Flags", true
                    ), "age" : readHeaderParam(
                    request.headers, "X-Age", false
                    ), "session_id" : readCookieParam(
                    request.headers, "sid", false
                    ), "prefs" : readCookieParam(
                    request.headers, "pref", true
                    ),
                };
                const payload = ifaceSchemas.test.HeaderServiceGetUserRequestSchema.parse(
                rawPayload
                );
                const result = await service.get_user(
                payload as ifaceTypes.test.HeaderServiceGetUserRequest
                );
                return encodeServerResponse(
                result, "application/json", "return", [
                {
                    name : "return", key : "return"
                }
                ], [

                ], [

                ], options.codecs??{
                }
                );

            },
        }, {
            method : "POST", path : "/v1/headers", handler : async(
            request, params
            ) => {
                const url = new URL(
                request.url
                );
                await authorizeRequest(
                request, [

                ], options
                );
                const rawPayload = {
                    "token" : readHeaderParam(
                    request.headers, "X-Token", false
                    ), "session_id" : readCookieParam(
                    request.headers, "sid", false
                    ),
                };
                const requestBody = await decodeRequestBody(
                request, "text/plain", options.codecs??{
                }, ifaceSchemas.test.HeaderServiceCreateUserRequestSchema
                );
                applyRequestBody(
                rawPayload, requestBody, "name", [
                "name"
                ]
                );
                const payload = ifaceSchemas.test.HeaderServiceCreateUserRequestSchema.parse(
                rawPayload
                );
                const result = await service.create_user(
                payload as ifaceTypes.test.HeaderServiceCreateUserRequest
                );
                return new Response(
                null, {
                    status : 204
                }
                );

            },
        },
        ], options,
        );
    }
}
