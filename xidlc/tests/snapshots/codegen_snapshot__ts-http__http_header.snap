                r
                ) => matchRoute(
                r.path, url.pathname
                )
                )
                .map(
                (
                r
                ) => r.method
                );
                return new Response(
                JSON.stringify(
                {
                    code : 405, msg : "Method Not Allowed"
                }
                ), {
                    status : 405, headers : {
                        "Content-Type" : "application/json", "Allow" : Array.from(
                        new Set(
                        allowed
                        )
                        ).join(
                        ", "
                        ),
                    },
                }
                );
            }

            return new Response(
            JSON.stringify(
            {
                code : 404, msg : "Not Found"
            }
            ), {
                status : 404, headers : {
                    "Content-Type" : "application/json"
                },
            }
            );

        }catch(error){
            if(options.onError){
                return await options.onError(
                error
                );
            }
            return errorResponse(
            error
            );
        }
    };
}

async function authorizeRequest(
