        baseUrl : string, options : ClientOptions = {
        }
        ){
            this.baseUrl = baseUrl;
            this.fetchImpl = resolveFetch(
            options.fetch
            );
            this.defaultHeaders = options.headers??{
            };
            this.auth = options.auth;
            this.codecs = options.codecs??{
            };
        }

        async get_user(
        id : number, req_id : string, flags : Array<
        string
        >, age : number, session_id : string, prefs : Array<
        string
        >
        ) : Promise<
        types.User
        >{
            const parsed = ifaceSchemas.test.HeaderServiceGetUserRequestSchema.parse(
            {
                "id" : id, "req_id" : req_id, "flags" : flags, "age" : age, "session_id" : session_id, "prefs" : prefs
            }
            );
            let path = "/v1/headers/{id}";
            path = path.replace(
            "{"+"id"+"}", encodePathSegment(
            id
            )
            );
            const query = new URLSearchParams(

            );
            const headers = new Headers(
            this.defaultHeaders
            );
            appendHeader(
            headers, "X-Req-Id", req_id, false, false
            );
            appendHeader(
            headers, "X-Flags", flags, false, true
            );
            appendHeader(
            headers, "X-Age", age, false, false
            );
            const cookies : string[] = [

            ];
            appendCookie(
            cookies, "sid", session_id, false, false
            );
            appendCookie(
            cookies, "pref", prefs, false, true
            );
            applyCookies(
            headers, cookies
            );
            applyClientAuth(
            path, query, headers, this.auth, [

            ]
            );
            const queryString = query.toString(

            );
            if(queryString.length>0){
                path = `${path}?${queryString}`;
            }
            const url = joinUrl(
            this.baseUrl, path
            );
            headers.set(
            "Accept", "application/json"
            );
            const resp = await this.fetchImpl(
            url, {
                method : "GET", headers
            }
            );
            if(!resp.ok){
                throw await parseXidlError(
                resp
                );
            }
            return await decodeResponseBody<
            types.User
            >(
            resp, "application/json", this.codecs
            );
        }

        async create_user(
        token : string, session_id : string, name : string
        ) : Promise<
        void
        >{
            const parsed = ifaceSchemas.test.HeaderServiceCreateUserRequestSchema.parse(
            {
                "token" : token, "session_id" : session_id, "name" : name
            }
            );
            let path = "/v1/headers";
            const query = new URLSearchParams(

            );
            const headers = new Headers(
            this.defaultHeaders
            );
            appendHeader(
            headers, "X-Token", token, false, false
            );
            const cookies : string[] = [

            ];
            appendCookie(
            cookies, "sid", session_id, false, false
            );
            applyCookies(
            headers, cookies
            );
            applyClientAuth(
            path, query, headers, this.auth, [

            ]
            );
            const queryString = query.toString(

            );
            if(queryString.length>0){
                path = `${path}?${queryString}`;
            }
            const url = joinUrl(
            this.baseUrl, path
            );
            const body = {
                "name" : parsed["name"]
            };
            headers.set(
            "Content-Type", "application/json"
            );
            headers.set(
            "Accept", "application/json"
            );
            const resp = await this.fetchImpl(
            url, {
                method : "POST", headers, body : encodeRequestBody(
                body, "application/json", this.codecs
                )
            }
            );
            if(!resp.ok){
                throw await parseXidlError(
                resp
