export class HttpStreamSseBindingsServiceClient{
    private readonly baseUrl : string;
    private readonly fetchImpl : FetchLike;
    private readonly defaultHeaders : Record<
    string, string
    >;
    constructor(
    baseUrl : string, options : ClientOptions = {
    }
    ){
        this.baseUrl = baseUrl;
        this.fetchImpl = resolveFetch(
        options.fetch
        );
        this.defaultHeaders = options.headers??{
        };
    }

    watch_project(
    project_id : string, cursor : string | undefined, trace_id : string
    ) : AsyncIterable<
    types.ProjectEvent
    >{
        const parsed = zodSchemas.HttpStreamSseBindingsServiceWatchProjectRequestSchema.parse(
        {
            "project_id" : project_id, "cursor" : cursor, "trace_id" : trace_id
        }
        );
        let path = "/projects/{project_id}/events";
        path = path.replace(
        "{"+"project_id"+"}", encodePathSegment(
        parsed["project_id"]
        )
        );
        const query = new URLSearchParams(

        );
        query.set(
        "cursor", encodeQueryValue(
        parsed["cursor"]
        )
        );
        const queryString = query.toString(

        );
        if(queryString.length>0){
            path = `${path}?${queryString}`;
        }
        const headers = new Headers(
        this.defaultHeaders
        );
        headers.set(
        "X-Trace-Id", encodeHeaderValue(
        parsed["trace_id"]
        )
        );
        const options = {
            method : "GET", headers
        };
        const url = joinUrl(
        this.baseUrl, path
        );
        return sseJsonStream<
        types.ProjectEvent
        >(
        this.fetchImpl, url, options
        );
    }
}
