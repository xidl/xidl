export class AClient{
    private readonly baseUrl : string;
    private readonly fetchImpl : FetchLike;
    private readonly defaultHeaders : Record<
    string, string
    >;
    constructor(
    baseUrl : string, options : ClientOptions = {
    }
    ){
        this.baseUrl = baseUrl;
        this.fetchImpl = resolveFetch(
        options.fetch
        );
        this.defaultHeaders = options.headers??{
        };
    }

    async opA(
    l_1 : types.L1
    ) : Promise<
    number
    >{
        const parsed = zodSchemas.AOpARequestSchema.parse(
        {
            "l_1" : l_1
        }
        );
        let path = "/opA";
        const body = parsed["l_1"];
        const headers = {
            ...this.defaultHeaders, "Content-Type" : "application/json"
        };
        const options = {
            method : "POST", headers, body : JSON.stringify(
            body
            )
        };
        const url = joinUrl(
        this.baseUrl, path
        );
        const resp = await this.fetchImpl(
        url, options
        );
        if(!resp.ok){
            throw await parseXidlError(
            resp
            );
        }
        const data = await resp.json(

        );
        return data as number;
    }
}
