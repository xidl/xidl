pub mod test{
    #[derive(
    Debug,
    Clone,
    Copy,
    PartialEq,
    Eq
    )]
    pub enum Status{
        OK,
        FAILED
    }

    pub struct User{
        pub id:u32,
        pub name:String,
        pub status:Status,
    }

    impl User{
    }
}
