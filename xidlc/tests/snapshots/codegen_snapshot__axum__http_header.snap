    pub struct HeaderServiceClient{
        client:xidl_rust_axum::Client,
    }

    impl HeaderServiceClient{
        pub fn new(base_url:impl Into<String>)->Self{
            Self{
                client:xidl_rust_axum::Client::new(base_url),
            }
        }

        pub fn with_auth(
        base_url:impl Into<String>,
        auth:xidl_rust_axum::ClientAuth,
        )->Self{
            Self{
                client:xidl_rust_axum::Client::with_auth(base_url,auth),
            }
        }

        pub fn with_http(
        base_url:impl Into<String>,
        http:xidl_rust_axum::reqwest::Client,
        )->Self{
            Self{
                client:xidl_rust_axum::Client::with_http(base_url,http),
            }
        }

        pub fn with_http_and_auth(
        base_url:impl Into<String>,
        http:xidl_rust_axum::reqwest::Client,
        auth:xidl_rust_axum::ClientAuth,
        )->Self{
            Self{
                client:xidl_rust_axum::Client::with_http_and_auth(base_url,http,auth),
            }
        }

        pub fn with_auth_override(
        &self,
        auth:Option<xidl_rust_axum::ClientAuth>,
        )->Self{
            Self{
                client:self.client.with_auth_override(auth),
            }
        }
    }

    impl HeaderServiceClient{
        pub async fn get_user(&self,id:u32,req_id:String,flags:Vec<String>,age:u32,session_id:String,prefs:Vec<String>)->Result<User,xidl_rust_axum::Error>{
            let path = "/v1/headers/{id}".to_string();
            let path = path.replace("{id}",&id.to_string());
            let mut req = self
            .client
            .http()
            .request(xidl_rust_axum::reqwest::Method::GET,self.client.url(&path))
            .build()
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
            req.headers_mut().insert(
            xidl_rust_axum::reqwest::header::ACCEPT,
            xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
            );
            let header_name = xidl_rust_axum::reqwest::header::HeaderName::from_bytes(
            "X-Req-Id".as_bytes(),
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            let header_value_str = req_id;
            let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(
            &header_value_str,
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            req.headers_mut().insert(header_name,header_value);
            let header_name = xidl_rust_axum::reqwest::header::HeaderName::from_bytes(
            "X-Flags".as_bytes(),
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            for value in flags{
                let header_value_str = value;
                let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(
                &header_value_str,
                )
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                req.headers_mut().append(header_name.clone(),header_value);
            }

            let header_name = xidl_rust_axum::reqwest::header::HeaderName::from_bytes(
            "X-Age".as_bytes(),
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            let header_value_str = age.to_string();
            let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(
            &header_value_str,
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            req.headers_mut().insert(header_name,header_value);
            let mut cookie_pairs:Vec<String> = Vec::new();
            let value_str = session_id;
            cookie_pairs.push(format!("{}={}","sid",value_str));
            for value in prefs{
                let value_str = value;
                cookie_pairs.push(format!("{}={}","pref",value_str));
            }

            if!cookie_pairs.is_empty(){
                let cookie_value = cookie_pairs.join("; ");
                let cookie_name = xidl_rust_axum::reqwest::header::HeaderName::from_static("cookie");
                let merged = match req.headers().get(&cookie_name){
                    Some(existing) => {
                        let existing = existing
                        .to_str()
                        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                        if existing.is_empty(){
                            cookie_value
                        }else{
                            format!("{existing}; {cookie_value}")
                        }
                    }
                    None => cookie_value,

                };
                let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(&merged)
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                req.headers_mut().insert(cookie_name,header_value);
            }

            let auth_target = &self.client;
            let resp = self
            .client
            .http()
            .execute(req)
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
            if resp.status().is_success(){
                let body = resp
                .bytes()
                .await
                .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
                xidl_rust_axum::DeserializeFactory::new("application/json")
                .from_slice(&body)
            }else{
                let status = resp.status();
                let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
                Err(xidl_rust_axum::Error::from_http_response(status,body))
            }
        }

        pub async fn create_user(&self,token:String,session_id:String,name:String)->Result<(),xidl_rust_axum::Error>{
            let path = "/v1/headers".to_string();
            let mut req = self
            .client
            .http()
            .request(xidl_rust_axum::reqwest::Method::POST,self.client.url(&path))
            .build()
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
            req.headers_mut().insert(
            xidl_rust_axum::reqwest::header::ACCEPT,
            xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
            );
            let header_name = xidl_rust_axum::reqwest::header::HeaderName::from_bytes(
            "X-Token".as_bytes(),
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            let header_value_str = token;
            let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(
            &header_value_str,
            )
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            req.headers_mut().insert(header_name,header_value);
            let mut cookie_pairs:Vec<String> = Vec::new();
            let value_str = session_id;
            cookie_pairs.push(format!("{}={}","sid",value_str));
            if!cookie_pairs.is_empty(){
                let cookie_value = cookie_pairs.join("; ");
                let cookie_name = xidl_rust_axum::reqwest::header::HeaderName::from_static("cookie");
                let merged = match req.headers().get(&cookie_name){
                    Some(existing) => {
                        let existing = existing
                        .to_str()
                        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                        if existing.is_empty(){
                            cookie_value
                        }else{
                            format!("{existing}; {cookie_value}")
                        }
                    }
                    None => cookie_value,

                };
                let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(&merged)
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                req.headers_mut().insert(cookie_name,header_value);
            }

            let auth_target = &self.client;
            let body = HeaderServiceCreateUserBody{
                name,
            };
            let body = xidl_rust_axum::SerializeFactory::new("application/json")
            .to_vec(&body)?;
            req.headers_mut().insert(
            xidl_rust_axum::reqwest::header::CONTENT_TYPE,
            xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
            );
            *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
            let resp = self
            .client
            .http()
            .execute(req)
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
            if resp.status().is_success(){
                Ok(())
            }else{
                let status = resp.status();
                let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
                Err(xidl_rust_axum::Error::from_http_response(status,body))
            }
        }
    }
