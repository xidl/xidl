        req:xidl_rust_axum::Request<HeaderServiceGetUserRequest>
        )->Result<User,xidl_rust_axum::Error>;
        async fn create_user(
        &self,
        req:xidl_rust_axum::Request<HeaderServiceCreateUserRequest>
        )->Result<(),xidl_rust_axum::Error>;
    }

