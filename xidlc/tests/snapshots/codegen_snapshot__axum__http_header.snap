        pub fn router(self)->xidl_rust_axum::axum::Router{
            let svc = self.inner;
            xidl_rust_axum::axum::Router::new()

            .route("/v1/headers/{id}",xidl_rust_axum::axum::routing::get(Self::get_user))

            .route("/v1/headers",xidl_rust_axum::axum::routing::post(Self::create_user))

            .with_state(svc)
        }

        #[allow(clippy::let_and_return,clippy::needless_return)]
        async fn get_user(
        ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
        headers: ::xidl_rust_axum::axum::http::HeaderMap,
        ::xidl_rust_axum::axum::extract::Path(path): ::xidl_rust_axum::axum::extract::Path<HeaderServiceGetUserPath>
        )->::xidl_rust_axum::Result<::xidl_rust_axum::axum::response::Response>{
            if!xidl_rust_axum::http::accepts_media_type(&headers,"application/json"){
                return Err(xidl_rust_axum::Error::not_acceptable());
            }

            let HeaderServiceGetUserPath{

            id,

            } = path;
            let req_id:String = match headers.get("X-Req-Id"){
                Some(header_value) => {
                    let header_str = header_value
                    .to_str()
                    .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                    header_str.to_string()
                }
                None => ::core::default::Default::default(),

            };
            let mut flags:Vec<String> = Vec::new();
            for header_value in headers.get_all("X-Flags").iter(){
                let header_str = header_value
                .to_str()
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                let parsed:String = header_str.to_string();
                flags.push(parsed);
            }

            if flags.is_empty(){
                let flags:Vec<String> = ::core::default::Default::default();

            }else{
                let flags:Vec<String> = flags;
            }

            let age:u32 = match headers.get("X-Age"){
                Some(header_value) => {
                    let header_str = header_value
                    .to_str()
                    .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                    header_str.parse()
                    .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?
                }
                None => ::core::default::Default::default(),

            };
            let mut cookie_map: ::std::collections::HashMap<String,Vec<String>> = ::std::collections::HashMap::new();
            for header_value in headers.get_all("cookie").iter(){
                let cookie_str = header_value
                .to_str()
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                for part in cookie_str.split(';'){
                    let part = part.trim();
                    if part.is_empty(){
                        continue;
                    }
                    let mut iter = part.splitn(2,'=');
                    let name = iter.next().unwrap_or("").trim();
                    if name.is_empty(){
                        continue;
                    }
                    let value = iter.next().unwrap_or("").trim().to_string();
                    cookie_map.entry(name.to_string()).or_default().push(value);
                }
            }

            let session_id:String = match cookie_map
            .get("sid")
            .and_then(|values|values.first()){
                Some(value) => value.to_string(),
                None => ::core::default::Default::default(),

            };
            let mut prefs:Vec<String> = Vec::new();
            if let Some(values) = cookie_map.get("pref"){
                for value in values{
                    let parsed:String = value.to_string();
                    prefs.push(parsed);
                }
            }

            if prefs.is_empty(){
                let prefs:Vec<String> = ::core::default::Default::default();

            }else{
                let prefs:Vec<String> = prefs;
            }

            let data = HeaderServiceGetUserRequest{
                id,
                req_id,
                flags,
                age,
                session_id,
                prefs,
            };
            let req = ::xidl_rust_axum::Request::new(headers,data);
            let mut resp = match svc.get_user(req).await{
                Ok(resp_value) => {
                    let mut resp = {
                        let body = xidl_rust_axum::SerializeFactory::new("application/json")
                        .to_vec(&resp_value)?;
                        ::xidl_rust_axum::axum::response::Response::builder()
                        .status(::xidl_rust_axum::axum::http::StatusCode::OK)
                        .header(
                        ::xidl_rust_axum::axum::http::header::CONTENT_TYPE,
                        "application/json",
                        )
                        .body(::xidl_rust_axum::axum::body::Body::from(body))
                        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?
                    }
                    ;
                    resp
                }
                Err(err) => ::xidl_rust_axum::axum::response::IntoResponse::into_response(err),

            };
            Ok(resp)
        }

        #[allow(clippy::let_and_return,clippy::needless_return)]
        async fn create_user(
        ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
        headers: ::xidl_rust_axum::axum::http::HeaderMap,
        body: ::xidl_rust_axum::axum::body::Body
        )->::xidl_rust_axum::Result<::xidl_rust_axum::axum::response::Response>{
            if!xidl_rust_axum::http::accepts_media_type(&headers,"application/json"){
                return Err(xidl_rust_axum::Error::not_acceptable());
            }

            if!xidl_rust_axum::http::content_type_matches(&headers,"application/json"){
                return Err(xidl_rust_axum::Error::unsupported_media_type());
            }

            let token:String = match headers.get("X-Token"){
                Some(header_value) => {
                    let header_str = header_value
                    .to_str()
                    .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                    header_str.to_string()
                }
                None => ::core::default::Default::default(),

            };
            let mut cookie_map: ::std::collections::HashMap<String,Vec<String>> = ::std::collections::HashMap::new();
            for header_value in headers.get_all("cookie").iter(){
                let cookie_str = header_value
                .to_str()
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                for part in cookie_str.split(';'){
                    let part = part.trim();
                    if part.is_empty(){
                        continue;
                    }
                    let mut iter = part.splitn(2,'=');
                    let name = iter.next().unwrap_or("").trim();
                    if name.is_empty(){
                        continue;
                    }
                    let value = iter.next().unwrap_or("").trim().to_string();
                    cookie_map.entry(name.to_string()).or_default().push(value);
                }
            }

            let session_id:String = match cookie_map
            .get("sid")
            .and_then(|values|values.first()){
                Some(value) => value.to_string(),
                None => ::core::default::Default::default(),

            };
            let body_bytes = ::xidl_rust_axum::axum::body::to_bytes(body,usize::MAX)
            .await
            .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
            let body:HeaderServiceCreateUserBody = xidl_rust_axum::DeserializeFactory::new("application/json")
            .from_slice(&body_bytes)?;
            let HeaderServiceCreateUserBody{

            name,

            } = body;
            let data = HeaderServiceCreateUserRequest{
                token,
                session_id,
                name,
            };
            let req = ::xidl_rust_axum::Request::new(headers,data);
            let mut resp = match svc.create_user(req).await{
                Ok(resp_value) => {
                    let mut resp = {
                        resp_value;
                        ::xidl_rust_axum::axum::response::IntoResponse::into_response(::xidl_rust_axum::axum::http::StatusCode::NO_CONTENT)
                    }
                    ;
                    resp
                }
                Err(err) => ::xidl_rust_axum::axum::response::IntoResponse::into_response(err),

            };
            Ok(resp)
        }
    }

