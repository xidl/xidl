pub struct HttpStreamSseBindingsServiceClient{
    client:xidl_rust_axum::Client,
}

impl HttpStreamSseBindingsServiceClient{
    pub fn new(base_url:impl Into<String>)->Self{
        Self{
            client:xidl_rust_axum::Client::new(base_url),
        }
    }
}

impl HttpStreamSseBindingsServiceClient{
    pub async fn watch_project(&self,project_id:String,cursor:Option<String>,trace_id:String)->Result<xidl_rust_axum::stream::Reader<ProjectEvent>,xidl_rust_axum::Error>{
        let path = "/projects/{project_id}/events".to_string();
        let path = path.replace("{project_id}",&project_id.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("text/event-stream")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        let header_name = xidl_rust_axum::reqwest::header::HeaderName::from_bytes(
        "X-Trace-Id".as_bytes(),
        )
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
        let header_value_str = trace_id;
        let header_value = xidl_rust_axum::reqwest::header::HeaderValue::from_str(
        &header_value_str,
        )
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
        req.headers_mut().insert(header_name,header_value);
        let query = HttpStreamSseBindingsServiceWatchProjectQuery{
            cursor,
        };
        let query = xidl_rust_axum::serde_urlencoded::to_string(&query)
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if!query.is_empty(){
            req.url_mut().set_query(Some(&query));
        }

        xidl_rust_axum::stream::open_sse::<ProjectEvent>(self.client.http(),req).await
    }
}
