    pub fn from_arc(inner: ::std::sync::Arc<T>)->Self{
        Self{
            inner}
    }

    pub fn router(self)->xidl_rust_axum::axum::Router{
        let svc = self.inner;
        xidl_rust_axum::axum::Router::new()

        .route("/projects/{project_id}/events",xidl_rust_axum::axum::routing::get(Self::watch_project))

        .with_state(svc)
    }

    async fn watch_project(
    ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
    headers: ::xidl_rust_axum::axum::http::HeaderMap,
    ::xidl_rust_axum::axum::extract::Path(path): ::xidl_rust_axum::axum::extract::Path<HttpStreamSseBindingsServiceWatchProjectPath>,
    xidl_rust_axum::axum::extract::Query(query):xidl_rust_axum::axum::extract::Query<HttpStreamSseBindingsServiceWatchProjectQuery>
    )->::xidl_rust_axum::Result<::xidl_rust_axum::axum::response::Response>{
        if!xidl_rust_axum::http::accepts_media_type(&headers,"text/event-stream"){
            return Err(xidl_rust_axum::Error::not_acceptable());
        }

        let HttpStreamSseBindingsServiceWatchProjectPath{

        project_id,

        } = path;
        let HttpStreamSseBindingsServiceWatchProjectQuery{

        cursor,

        } = query;
        let trace_id:String = match headers.get("X-Trace-Id"){
            Some(header_value) => {
                let header_str = header_value
                .to_str()
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                header_str.to_string()
            }
            None => ::core::default::Default::default(),

        };
        let data = HttpStreamSseBindingsServiceWatchProjectRequest{
            project_id,
            cursor,
            trace_id,
        };
        let req = ::xidl_rust_axum::Request::new(headers,data);
        let resp = svc.watch_project(req).await?;
        Ok(xidl_rust_axum::stream::sse_response(resp))
    }
}

