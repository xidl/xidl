#[async_trait::async_trait]
pub trait HttpService{
    async fn get_health(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<HealthResponse,xidl_rust_axum::Error>;
    async fn get_version(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<VersionResponse,xidl_rust_axum::Error>;
    async fn get_memory_info(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<MemoryResponse,xidl_rust_axum::Error>;
    async fn restart(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<(),xidl_rust_axum::Error>;
    async fn get_state(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<crate::api::state::StateResponse,xidl_rust_axum::Error>;
    async fn get_udp_stats(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<UdpStatsResponse,xidl_rust_axum::Error>;
    async fn create_simple(
    &self,
    req:xidl_rust_axum::Request<HttpServiceCreateSimpleRequest>
    )->Result<CreateSimpleResponse,xidl_rust_axum::Error>;
    async fn stop_simple(
    &self,
    req:xidl_rust_axum::Request<HttpServiceStopSimpleRequest>
    )->Result<(),xidl_rust_axum::Error>;
}

#[derive(::serde::Serialize,::serde::Deserialize)]
struct HttpServiceCreateSimpleBody{
    local_addr:String,
    remote_port:u16,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
pub struct HttpServiceCreateSimpleRequest{
    pub local_addr:String,
    pub remote_port:u16,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
struct HttpServiceStopSimplePath{
    id:u32,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
pub struct HttpServiceStopSimpleRequest{
    pub id:u32,
}

pub struct HttpServiceServer<T>{
    inner: ::std::sync::Arc<T>,
}

impl<T>HttpServiceServer<T>
where
T:HttpService+Send+Sync+'static,
{
    pub fn new(inner:T)->Self{
        Self{
            inner: ::std::sync::Arc::new(inner),
        }
    }

    pub fn from_arc(inner: ::std::sync::Arc<T>)->Self{
        Self{
            inner}
    }

    pub fn router(self)->xidl_rust_axum::axum::Router{
        let svc = self.inner;
        xidl_rust_axum::axum::Router::new()

        .route("/api/v1/health",xidl_rust_axum::axum::routing::get(Self::get_health))

        .route("/api/v1/app/version",xidl_rust_axum::axum::routing::get(Self::get_version))

        .route("/api/v1/app/memory",xidl_rust_axum::axum::routing::get(Self::get_memory_info))

        .route("/api/v1/app/restart",xidl_rust_axum::axum::routing::get(Self::restart))

        .route("/api/v1/proxy/state",xidl_rust_axum::axum::routing::get(Self::get_state))

