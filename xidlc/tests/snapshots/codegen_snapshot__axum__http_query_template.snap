impl HttpQueryTemplateServiceClient{
    pub async fn get_user(&self,id:u32,lang:String,region:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/users/{id}".to_string();
        let path = path.replace("{{id}}",&id.to_string());
        let url = self.client.url(&path);
        let req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url);
        let query = HttpQueryTemplateServiceGetUserQuery{
            lang,
            region,
        };
        let req = req.query(&query);
        let resp = req
        .send()
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }

    pub async fn search(&self,keyword:String,payload:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/search".to_string();
        let url = self.client.url(&path);
        let req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url);
        let query = HttpQueryTemplateServiceSearchQuery{
            keyword,
        };
        let req = req.query(&query);
        let body = payload;
        let req = req.json(&body);
        let resp = req
        .send()
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }
