pub struct HttpQueryTemplateServiceClient{
    client:xidl_rust_axum::Client,
}

impl HttpQueryTemplateServiceClient{
    pub fn new(base_url:impl Into<String>)->Self{
        Self{
            client:xidl_rust_axum::Client::new(base_url),
        }
    }
}

impl HttpQueryTemplateServiceClient{
    pub async fn get_user(&self,id:u32,lang:String,region:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/users/{id}".to_string();
        let path = path.replace("{id}",&id.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let query = HttpQueryTemplateServiceGetUserQuery{
            lang,
            region,
        };
        let query = xidl_rust_axum::serde_urlencoded::to_string(&query)
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if!query.is_empty(){
            req.url_mut().set_query(Some(&query));
        }

        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }

    pub async fn search(&self,keyword:String,payload:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/search".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let query = HttpQueryTemplateServiceSearchQuery{
            keyword,
        };
        let query = xidl_rust_axum::serde_urlencoded::to_string(&query)
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if!query.is_empty(){
            req.url_mut().set_query(Some(&query));
        }

        let body = payload;
        let body = xidl_rust_axum::serde_json::to_vec(&body)
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
        xidl_rust_axum::reqwest::header::HeaderValue::from_static("application/json"),
        );
        *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }
