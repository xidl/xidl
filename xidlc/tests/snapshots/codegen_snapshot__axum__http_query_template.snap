        const parsed = zodSchemas.HttpQueryTemplateServiceGetUserRequestSchema.parse(
        {
            "id" : id, "lang" : lang, "region" : region
        }
        );
        let path = "/users/{id}";
        path = path.replace(
        "{"+"id"+"}", encodePathSegment(
        parsed["id"]
        )
        );
        const query = new URLSearchParams(

        );
        query.set(
        "lang", encodeQueryValue(
        parsed["lang"]
        )
        );
        query.set(
        "region", encodeQueryValue(
        parsed["region"]
        )
        );
        const queryString = query.toString(

        );
        if(queryString.length>0){
            path = `${path}?${queryString}`;
        }

        const headers = {
            ...this.defaultHeaders
        };
        const options = {
            method : "GET", headers
        };
        const url = joinUrl(
        this.baseUrl, path
        );
        const resp = await this.fetchImpl(
        url, options
        );
        if(!resp.ok){
            throw await parseXidlError(
            resp
            );
        }
        const data = await resp.json(

        );
        return data as string;
    }

    async search(
    keyword : string, payload : string
    ) : Promise<
    string
    >{
        const parsed = zodSchemas.HttpQueryTemplateServiceSearchRequestSchema.parse(
        {
            "keyword" : keyword, "payload" : payload
        }
        );
        let path = "/search";
        const query = new URLSearchParams(

        );
        query.set(
        "keyword", encodeQueryValue(
        parsed["keyword"]
        )
        );
        const queryString = query.toString(

        );
        if(queryString.length>0){
            path = `${path}?${queryString}`;
        }

        const body = parsed["payload"];
        const headers = {
            ...this.defaultHeaders, "Content-Type" : "application/json"
