    ).toLowerCase(

    )??"application/json";
}

function encodeScalar(
value : unknown
) : string{
    if(typeof value==="string"||typeof value==="number"||typeof value==="boolean"){
        return String(
        value
        );
    }
    return JSON.stringify(
    value
    );
}

function parseScalar(
value : string
) : unknown{
    if(value==="true"){
        return true;
    }
    if(value==="false"){
        return false;
    }
    if(/^-?\d+(\.\d+)?$/.test(
    value
    )){
        return Number(
        value
        );
    }
    try{
        return JSON.parse(
        value
