function errorResponse(
error : unknown
) : Response{
    if(error instanceof XidlServerError){
        return new Response(
        JSON.stringify(
        {
            code : error.code, msg : error.message
        }
        ), {
            status : error.status, headers : {
                "Content-Type" : "application/json"
            },
        }
        );
    }
    const message = error instanceof Error ?error.message : "internal server error";
    return new Response(
    JSON.stringify(
    {
        code : 500, msg : message
    }
    ), {
        status : 500, headers : {
            "Content-Type" : "application/json"
        },
    }
    );
}

export interface HttpStreamSseBindingsService{
    watch_project(
    req : ifaceTypes.HttpStreamSseBindingsServiceWatchProjectRequest
    ) : Awaitable<
    AsyncIterable<
    types.ProjectEvent
    >
    >;
}

export function createHttpStreamSseBindingsServiceHandler(
service : HttpStreamSseBindingsService, options : ServerOptions = {
},
) : ServerHandler{
    return createRouter(
    [
    {
        method : "GET", path : "/projects/{project_id}/events", handler : async(
        request, params
        ) => {
            const url = new URL(
            request.url
            );
            await authorizeRequest(
            request, [

            ], options
            );
            const rawPayload = {
                "project_id" : readPathParam(
                params, "project_id"
                ), "cursor" : readQueryParam(
                url.searchParams, "cursor", false
                ), "trace_id" : readHeaderParam(
                request.headers, "X-Trace-Id", false
                ),
            };
            const payload = ifaceSchemas.HttpStreamSseBindingsServiceWatchProjectRequestSchema.parse(
            rawPayload
            );
            const result = await service.watch_project(
            payload as ifaceTypes.HttpStreamSseBindingsServiceWatchProjectRequest
            );
            return sseResponse(
            result, options
            );

        },
    },
    ], options,
    );
}
