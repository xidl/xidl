function encodeServerResponse(
value : unknown, contentType : string, bodyMode : string, bodyFields : ResponseFieldSpec[], headerFields : ResponseFieldSpec[], cookieFields : ResponseFieldSpec[], codecs : Record<
string, HttpCodec
>,
) : Response{
