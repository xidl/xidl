pub struct C{
    tag:i32,
    data:CData,
}

union CData{
    a:core::mem::ManuallyDrop<i32>,
    b:core::mem::ManuallyDrop<String>,
}

impl Drop for C{
    fn drop(&mut self){
        match self.tag{
            0 => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.a);
                }
            }
            1 => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.b);
                }
            }
        }
    }
}

impl C{
    pub const SERIALIZE_KIND:xidl_xcdr::SerializeKind = xidl_xcdr::SerializeKind::Cdr;
    pub fn new_a(value:i32)->Self{
        Self{
            tag:0,
            data:CData{
                a:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_a(&self)->bool{
        matches!(self.tag,0)
    }

    pub fn as_a(&self)->&i32{
        debug_assert!(self.is_a());
        unsafe{
            &self.data.a
        }
    }

    pub fn as_a_mut(&mut self)->&mut i32{
        debug_assert!(self.is_a());
        unsafe{
            &mut self.data.a
        }
    }

    pub fn into_a(self)->i32{
        debug_assert!(self.is_a());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.a)
        }
    }

    pub fn new_b(value:String)->Self{
        Self{
            tag:1,
            data:CData{
                b:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_b(&self)->bool{
        matches!(self.tag,1)
    }

    pub fn as_b(&self)->&String{
        debug_assert!(self.is_b());
        unsafe{
            &self.data.b
        }
    }

    pub fn as_b_mut(&mut self)->&mut String{
        debug_assert!(self.is_b());
        unsafe{
            &mut self.data.b
        }
    }

    pub fn into_b(self)->String{
        debug_assert!(self.is_b());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.b)
        }
    }

    pub fn tag(&self)->&i32{
        &self.tag
    }
}

impl xidl_xcdr::XcdrSerialize for C{
    fn serialize_kind(&self)->xidl_xcdr::SerializeKind{
        Self::SERIALIZE_KIND
    }

    fn serialize_with<S:xidl_xcdr::XcdrSerializer+?Sized>(
    &self,
    serializer:&mut S,
    )->xidl_xcdr::error::XcdrResult<()>{
        serializer.begin_struct_with_kind(Self::SERIALIZE_KIND)?;
        serializer.begin_field(xidl_xcdr::FieldId(0),false,0)?;
        xidl_xcdr::XcdrSerialize::serialize_with(&self.tag,serializer)?;
        serializer.end_field()?;
        match self.tag{
            0 => {
                let value = unsafe{
                    self.data.a.as_ref()
                };
                serializer.begin_field(xidl_xcdr::FieldId(1u32),false,0)?;
                xidl_xcdr::XcdrSerialize::serialize_with(value,serializer)?;
                serializer.end_field()?;

            },
            1 => {
                let value = unsafe{
                    self.data.b.as_ref()
                };
                serializer.begin_field(xidl_xcdr::FieldId(2u32),false,0)?;
                xidl_xcdr::XcdrSerialize::serialize_with(value,serializer)?;
                serializer.end_field()?;

            },
            _ => {
            }
        }
        serializer.end_struct()?;
        Ok(())
    }
}

