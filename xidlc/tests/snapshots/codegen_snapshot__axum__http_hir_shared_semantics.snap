struct ReportApiGetReportPath{
    id:String,
}

#[derive(::serde::Serialize,::serde::Deserialize,::core::default::Default)]
struct ReportApiGetReportQuery{
    #[serde(default)]

    lang:Option<String>,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
pub struct ReportApiGetReportRequest{
    pub id:String,
    pub lang:Option<String>,
    pub trace_id:String,
    pub xidl_auth:xidl_rust_axum::auth::bearer::BearerAuth,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
struct ReportApiWatchReportPath{
    id:String,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
pub struct ReportApiWatchReportRequest{
    pub id:String,
    pub xidl_auth:xidl_rust_axum::auth::bearer::BearerAuth,
}

pub struct ReportApiServer<T>{
    inner: ::std::sync::Arc<T>,
}

impl<T>ReportApiServer<T>
where
T:ReportApi+Send+Sync+'static,
{
    pub fn new(inner:T)->Self{
        Self{
            inner: ::std::sync::Arc::new(inner),
        }
    }

    pub fn from_arc(inner: ::std::sync::Arc<T>)->Self{
        Self{
            inner}
    }

    pub fn router(self)->xidl_rust_axum::axum::Router{
        let svc = self.inner;
        xidl_rust_axum::axum::Router::new()

        .route("/reports/{id}",xidl_rust_axum::axum::routing::get(Self::get_report))

        .route("/reports/{id}/events",xidl_rust_axum::axum::routing::get(Self::watch_report))

        .with_state(svc)
    }

    async fn get_report(
    ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
    headers: ::xidl_rust_axum::axum::http::HeaderMap,
    auth_header:Option<::xidl_rust_axum::axum_extra::extract::TypedHeader<::xidl_rust_axum::auth::bearer::BearerHeader>>,
    ::xidl_rust_axum::axum::extract::Path(path): ::xidl_rust_axum::axum::extract::Path<ReportApiGetReportPath>,
    xidl_rust_axum::axum::extract::Query(query):xidl_rust_axum::axum::extract::Query<ReportApiGetReportQuery>
    )->::xidl_rust_axum::Result<::xidl_rust_axum::axum::response::Response>{
        if!xidl_rust_axum::http::accepts_media_type(&headers,"application/json"){
            return Err(xidl_rust_axum::Error::not_acceptable());
        }

        let xidl_auth = match auth_header{
            Some(::xidl_rust_axum::axum_extra::extract::TypedHeader(auth_header)) => {
                xidl_rust_axum::auth::bearer::BearerAuth::from_header(auth_header)
            }
            None => return Err(xidl_rust_axum::Error::unauthorized()),

        };
        let ReportApiGetReportPath{

        id,

        } = path;
        let ReportApiGetReportQuery{

        lang,

        } = query;
        let trace_id:String = match headers.get("X-Trace-Id"){
            Some(header_value) => {
                let header_str = header_value
                .to_str()
                .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?;
                header_str.to_string()
            }
            None => ::core::default::Default::default(),

        };
        let data = ReportApiGetReportRequest{
            id,
            lang,
            trace_id,
            xidl_auth,
        };
        let req = ::xidl_rust_axum::Request::new(headers,data);
        let mut resp = match svc.get_report(req).await{
            Ok(resp_value) => {
                let mut resp = {
                    let body = xidl_rust_axum::SerializeFactory::new("application/json")
                    .to_vec(&resp_value)?;
                    ::xidl_rust_axum::axum::response::Response::builder()
                    .status(::xidl_rust_axum::axum::http::StatusCode::OK)
                    .header(
                    ::xidl_rust_axum::axum::http::header::CONTENT_TYPE,
                    "application/json",
                    )
                    .body(::xidl_rust_axum::axum::body::Body::from(body))
                    .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?
                };
                resp
            }
            Err(err) => ::xidl_rust_axum::axum::response::IntoResponse::into_response(err),

        };
        Ok(resp)
    }

    async fn watch_report(
    ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
    headers: ::xidl_rust_axum::axum::http::HeaderMap,
    auth_header:Option<::xidl_rust_axum::axum_extra::extract::TypedHeader<::xidl_rust_axum::auth::bearer::BearerHeader>>,
