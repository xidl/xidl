#[async_trait::async_trait]
pub trait ReportApi{
    async fn get_report(
    &self,
    req:xidl_rust_axum::Request<ReportApiGetReportRequest>
    )->Result<String,xidl_rust_axum::Error>;
    async fn watch_report(
    &self,
    req:xidl_rust_axum::Request<ReportApiWatchReportRequest>
    )->Result<xidl_rust_axum::stream::SseStream<String>,xidl_rust_axum::Error>;
}

