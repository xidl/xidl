    pub async fn watch_topic(&self,topic:String,lang:String)->Result<xidl_rust_axum::stream::Reader<String>,xidl_rust_axum::Error>{
        let path = "/events/{topic}".to_string();
        let path = path.replace("{topic}",&topic.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let query = HttpStreamSseServiceWatchTopicQuery{
            lang,
        };
        let query = xidl_rust_axum::serde_urlencoded::to_string(&query)
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if!query.is_empty(){
            req.url_mut().set_query(Some(&query));
        }

        xidl_rust_axum::stream::open_sse::<String>(self.client.http(),req).await
    }

    pub async fn online(&self)->Result<bool,xidl_rust_axum::Error>{
        let path = "/HttpStreamSseService/online".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<bool>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }

    pub async fn set_online(&self,value:bool)->Result<(),xidl_rust_axum::Error>{
        let path = "/HttpStreamSseService/set_online".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        let body = value;
        let body = xidl_rust_axum::serde_json::to_vec(&body)
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
        xidl_rust_axum::reqwest::header::HeaderValue::from_static("application/json"),
        );
        *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            Ok(())
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }

    pub async fn watch_attribute_online(&self)->Result<xidl_rust_axum::stream::Reader<bool>,xidl_rust_axum::Error>{
