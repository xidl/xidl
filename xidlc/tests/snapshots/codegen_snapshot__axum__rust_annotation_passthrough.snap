    &self,
    req:xidl_rust_axum::Request<RustHttpGetUserRequest>
    )->Result<String,xidl_rust_axum::Error>;
    #[cfg(feature = "server")]

    async fn display_name(
    &self,
    req:xidl_rust_axum::Request<()>
    )->Result<String,xidl_rust_axum::Error>;
    #[cfg(feature = "server")]

    async fn set_display_name(
    &self,
    req:xidl_rust_axum::Request<RustHttpSetDisplayNameRequest>
    )->Result<(),xidl_rust_axum::Error>;
}

