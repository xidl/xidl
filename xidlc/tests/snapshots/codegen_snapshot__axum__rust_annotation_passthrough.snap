pub struct RustHttpClient{
    client:xidl_rust_axum::Client,
}

impl RustHttpClient{
    pub fn new(base_url:impl Into<String>)->Self{
        Self{
            client:xidl_rust_axum::Client::new(base_url),
        }
    }
}

impl RustHttpClient{
    pub async fn get_user(&self,user_id:u32)->Result<String,xidl_rust_axum::Error>{
        let path = "/users/{user_id}".to_string();
        let path = path.replace("{user_id}",&user_id.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }

    pub async fn display_name(&self)->Result<String,xidl_rust_axum::Error>{
        let path = "/RustHttp/display_name".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }

    pub async fn set_display_name(&self,value:String)->Result<(),xidl_rust_axum::Error>{
        let path = "/RustHttp/set_display_name".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        let body = value;
        let body = xidl_rust_axum::serde_json::to_vec(&body)
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("application/json")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
        let resp = self
        .client
        .http()
        .execute(req)
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        if resp.status().is_success(){
            Ok(())
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            Err(xidl_rust_axum::Error::from_http_response(status,body))
        }
    }
}
