        Self{
            inner: ::std::sync::Arc::new(inner),
        }
    }

    pub fn from_arc(inner: ::std::sync::Arc<T>)->Self{
        Self{
            inner}
    }

    pub fn router(self)->xidl_rust_axum::axum::Router{
        let svc = self.inner;
        xidl_rust_axum::axum::Router::new()

        .route("/users/{user_id}",xidl_rust_axum::axum::routing::get(Self::get_user))

        .route("/RustHttp/display_name",xidl_rust_axum::axum::routing::get(Self::display_name))

