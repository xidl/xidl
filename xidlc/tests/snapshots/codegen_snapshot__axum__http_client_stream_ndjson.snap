#[async_trait::async_trait]
pub trait HttpClientStreamService{
    async fn upload_chunk(
    &self,
    req:xidl_rust_axum::Request<xidl_rust_axum::stream::NdjsonStream<HttpClientStreamServiceUploadChunkRequest>>
    )->Result<String,xidl_rust_axum::Error>;
}

#[derive(::serde::Serialize,::serde::Deserialize)]
struct HttpClientStreamServiceUploadChunkBody{
    file_id:String,
    chunk:Vec<u8>,
}

#[derive(::serde::Serialize,::serde::Deserialize)]
pub struct HttpClientStreamServiceUploadChunkRequest{
    pub file_id:String,
    pub chunk:Vec<u8>,
}

pub struct HttpClientStreamServiceServer<T>{
    inner: ::std::sync::Arc<T>,
}

impl<T>HttpClientStreamServiceServer<T>
where
T:HttpClientStreamService+Send+Sync+'static,
{
    pub fn new(inner:T)->Self{
        Self{
            inner: ::std::sync::Arc::new(inner),
        }
    }

    pub fn from_arc(inner: ::std::sync::Arc<T>)->Self{
        Self{
            inner}
    }

    pub fn router(self)->xidl_rust_axum::axum::Router{
        let svc = self.inner;
        xidl_rust_axum::axum::Router::new()

        .route("/upload/chunks",xidl_rust_axum::axum::routing::post(Self::upload_chunk))

        .with_state(svc)
    }

    async fn upload_chunk(
    ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
    headers: ::xidl_rust_axum::axum::http::HeaderMap,
    body: ::xidl_rust_axum::axum::body::Body
    )->::xidl_rust_axum::Result<::xidl_rust_axum::axum::response::Response>{
        let data = xidl_rust_axum::stream::decode_ndjson_body::<HttpClientStreamServiceUploadChunkRequest>(body);
        let req = ::xidl_rust_axum::Request::new(headers,data);
        let resp = svc.upload_chunk(req).await?;
        Ok(::xidl_rust_axum::axum::response::IntoResponse::into_response(xidl_rust_axum::axum::Json(resp)))
    }
}

impl<T>xidl_rust_axum::Service for HttpClientStreamServiceServer<T>
where
T:HttpClientStreamService+Send+Sync+'static,
{
    fn into_router(self)->xidl_rust_axum::axum::Router{
        self.router()
    }
}

pub struct HttpClientStreamServiceClient{
    client:xidl_rust_axum::Client,
}

impl HttpClientStreamServiceClient{
    pub fn new(base_url:impl Into<String>)->Self{
        Self{
            client:xidl_rust_axum::Client::new(base_url),
        }
    }
}

impl HttpClientStreamServiceClient{
    pub async fn upload_chunk(&self)->Result<xidl_rust_axum::stream::Writer<HttpClientStreamServiceUploadChunkRequest,String>,xidl_rust_axum::Error>{
        let path = "/upload/chunks".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
        xidl_rust_axum::reqwest::header::HeaderValue::from_static("application/x-ndjson"),
        );
        let(tx,rx) = xidl_rust_axum::tokio::sync::mpsc::channel(32);
        let outbound = xidl_rust_axum::futures_util::stream::unfold(rx,|mut rx|async move{
            rx.recv().await.map(|item|(item,rx))
        });
        *req.body_mut() = Some(xidl_rust_axum::stream::encode_ndjson_body(Box::pin(outbound)));
        let http = self.client.http().clone();
        let response_task = xidl_rust_axum::tokio::spawn(async move{
            let resp = http
            .execute(req)
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
            if resp.status().is_success(){
                resp.json::<String>()
                .await
                .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
            }else{
                let status = resp.status();
                let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
                Err(xidl_rust_axum::Error::from_http_response(status,body))
            }
        });
        return Ok(xidl_rust_axum::stream::Writer::new(tx,response_task));
    }
}
