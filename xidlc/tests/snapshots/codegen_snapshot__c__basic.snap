#ifndef BASIC_H
#define BASIC_H
#include<stdbool.h>
#include<stdint.h>
#include<wchar.h>

typedef struct Point{
    int32_t x;
    int32_t y;

}Point;
Point Point_new(void);
void Point_init(Point * self);
#endif
