impl HttpDefaultsServiceClient{
    pub async fn get_name(&self,name:String)->Result<String,xidl_rust_axum::Error>{
        let path = "/get_name".to_string();
        let url = self.client.url(&path);
        let req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url);
        let query = HttpDefaultsServiceGetNameQuery{
            name,
        };
        let req = req.query(&query);
        let resp = req
        .send()
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }

    pub async fn list_orders(&self,user_id:u32,page:u32,size:u32)->Result<String,xidl_rust_axum::Error>{
        let path = "/list_orders/{uid}".to_string();
        let path = path.replace("{{uid}}",&user_id.to_string());
        let url = self.client.url(&path);
        let req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url);
        let query = HttpDefaultsServiceListOrdersQuery{
            page,
            size,
        };
        let req = req.query(&query);
        let resp = req
        .send()
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<String>()
