    );
    const payload = value&&typeof value==="object" ?(value as Record<
    string, unknown
    >) : {
    };
    for(const field of headerFields){
        writeHeader(
        headers, field.name, payload[field.key], field.isMulti??false
        );
    }
    for(const field of cookieFields){
        writeCookie(
        headers, field.name, payload[field.key], field.isMulti??false
        );
    }
    if(bodyMode==="none"){
        return new Response(
        null, {
            status : 204, headers
        }
        );
    }
    const body = bodyMode==="return" ?bodyFields[0]?.key==="return" ?value : payload[bodyFields[0]?.key??"return"] : Object.fromEntries(
    bodyFields.map(
    (
    field
    ) => [
    field.name, payload[field.key]
    ]
    ).filter(
    (
    entry
    ) => entry[1]!==undefined
    ),
    );
    headers.set(
    "Content-Type", contentType
    );
    return new Response(
    encodeBody(
    body, contentType, codecs
    ), {
        status : 200, headers
    }
    );
}

function writeHeader(
headers : Headers, name : string, value : unknown, isMulti : boolean
) : void{
    if(value===undefined||value===null){
        return;
    }
    if(isMulti&&Array.isArray(
    value
    )){
        for(const item of value){
            headers.append(
            name, encodeScalar(
            item
            )
            );
        }
        return;
    }
    headers.set(
    name, encodeScalar(
    value
    )
    );
}

function writeCookie(
headers : Headers, name : string, value : unknown, isMulti : boolean
) : void{
    if(value===undefined||value===null){
        return;
    }
    const items = isMulti&&Array.isArray(
    value
    ) ?value : [
    value
    ];
    for(const item of items){
        headers.append(
        "Set-Cookie", `${name}=${encodeURIComponent(
            encodeScalar(
            item
            )
            )}`
        );
    }
}

function encodeBody(
value : unknown, contentType : string, codecs : Record<
string, HttpCodec
>,
) : BodyInit | null{
    const mime = normalizeMime(
    contentType
    );
    const custom = codecs[mime]?.encode;
    if(custom){
        return custom(
        value
        );
    }
    if(mime==="application/json"||mime.endsWith(
    "+json"
    )){
        return JSON.stringify(
        value
        );
    }
    if(mime.startsWith(
    "text/"
    )){
        return String(
        value??""
        );
    }
    throw new XidlServerError(
    `unsupported response content type: ${mime}`, 500
    );
}

function normalizeMime(
value : string
) : string{
    return value.split(
    ";"
    )[0]?.trim(

    ).toLowerCase(

    )??"application/json";
}

function encodeScalar(
value : unknown
) : string{
    if(typeof value==="string"||typeof value==="number"||typeof value==="boolean"){
        return String(
        value
        );
    }
    return JSON.stringify(
    value
    );
}

function parseScalar(
value : string
) : unknown{
    if(value==="true"){
        return true;
    }
    if(value==="false"){
        return false;
    }
    if(/^-?\d+(\.\d+)?$/.test(
    value
    )){
        return Number(
        value
        );
    }
    try{
        return JSON.parse(
        value
        );

    }catch{
        return value;
    }
}

function errorResponse(
error : unknown
) : Response{
    if(error instanceof XidlServerError){
        return new Response(
        JSON.stringify(
        {
            code : error.code, msg : error.message
        }
        ), {
            status : error.status, headers : {
