    switch (auth.kind) {
        case "basic":
        headers.set("Authorization", `Basic ${btoa(`${auth.username}:${auth.password}`)}`);
        break;
        case "bearer":
        case "oauth2":
        headers.set("Authorization", `Bearer ${auth.token}`);
        break;
        case "api_key": {
            const name = auth.name ?? match.name ?? "x-api-key";
            const location = auth.location ?? match.location ?? "header";
