        // ignored
    }
    return new XidlClientError(`http error: ${status}`, status, status);
}

async function* sseJsonStream<T>(
fetchImpl: FetchLike,
url: string,
options: RequestInit,
schema?: z.ZodTypeAny,
): AsyncIterable<T> {
    const resp = await fetchImpl(url, options);
    if (!resp.ok) {
        throw await parseXidlError(resp);
    }
    if (!resp.body) {
        throw new XidlClientError("sse response has no body", 500, resp.status);
    }
    const reader = resp.body.getReader();
    const decoder = new TextDecoder();
