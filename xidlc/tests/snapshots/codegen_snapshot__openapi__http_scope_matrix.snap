      },
      "oauth2": {
        "flows": {
          "clientCredentials": {
            "scopes": {
              "reports:read": "reports:read",
              "reports:write": "reports:write"
            },
            "tokenUrl": "https://example.invalid/token"
          }
        },
        "type": "oauth2"
      }
    }
  },
