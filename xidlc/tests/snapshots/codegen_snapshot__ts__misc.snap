#[derive(
Debug,
Clone,
Copy,
PartialEq,
Eq
)]
pub enum Color{
    red,
    green,
    blue
}

pub const FAVORITE_COLOR:Color = red;
pub const MYSIZE:M::Size = M::medium;
pub const col:Color = red;
pub const another:Color = M::medium;
pub type FooSeq = Vec<Foo>;
pub type FooSeq = Vec<Foo>;
pub type FooSeq = Vec<Foo>;
pub struct Foo{
    pub value:i32,
    pub chain:FooSeq,
}

impl Foo{
}

pub type BarSeq = Vec<Bar>;
pub struct Bar{
    tag:i32,
    data:BarData,
}

union BarData{
    l_mem:core::mem::ManuallyDrop<i32>,
    s_mem:core::mem::ManuallyDrop<Foo>,
}

impl Drop for Bar{
    fn drop(&mut self){
        match self.tag{
            0 => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.l_mem);
                }
            }
            1 => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.s_mem);
                }
            }
        }
    }
}

impl Bar{
    pub fn new_l_mem(value:i32)->Self{
        Self{
            tag:0,
            data:BarData{
                l_mem:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_l_mem(&self)->bool{
        matches!(self.tag,0)
    }

    pub fn as_l_mem(&self)->&i32{
        debug_assert!(self.is_l_mem());
        unsafe{
            &self.data.l_mem
        }
    }

    pub fn as_l_mem_mut(&mut self)->&mut i32{
        debug_assert!(self.is_l_mem());
        unsafe{
            &mut self.data.l_mem
        }
    }

    pub fn into_l_mem(self)->i32{
        debug_assert!(self.is_l_mem());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.l_mem)
        }
    }

    pub fn new_s_mem(value:Foo)->Self{
        Self{
            tag:1,
            data:BarData{
                s_mem:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_s_mem(&self)->bool{
        matches!(self.tag,1)
    }

    pub fn as_s_mem(&self)->&Foo{
        debug_assert!(self.is_s_mem());
        unsafe{
            &self.data.s_mem
        }
    }

    pub fn as_s_mem_mut(&mut self)->&mut Foo{
        debug_assert!(self.is_s_mem());
        unsafe{
            &mut self.data.s_mem
        }
    }

    pub fn into_s_mem(self)->Foo{
        debug_assert!(self.is_s_mem());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.s_mem)
        }
    }

    pub fn tag(&self)->&i32{
        &self.tag
    }
}

