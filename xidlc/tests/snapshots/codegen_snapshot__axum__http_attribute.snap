    pub async fn set_name(&self,value:String)->Result<(),xidl_rust_axum::Error>{
        let path = "/HttpAttributeService/set_name".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url)
