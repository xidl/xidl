impl HttpSecurityStreamServiceClient{
    pub async fn watch_channel(&self,channel:String)->Result<xidl_rust_axum::stream::Reader<String>,xidl_rust_axum::Error>{
        let path = "/channels/{channel}/events".to_string();
        let path = path.replace("{channel}",&channel.to_string());
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("text/event-stream")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        xidl_rust_axum::stream::open_sse::<String>(self.client.http(),req).await
    }

    pub async fn watch_public(&self)->Result<xidl_rust_axum::stream::Reader<String>,xidl_rust_axum::Error>{
        let path = "/channels/public/events".to_string();
        let url = self.client.url(&path);
        let mut req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::GET,url)
        .build()
        .map_err(|err|xidl_rust_axum::Error::new(500,format!("{err:?}")))?;
        req.headers_mut().insert(
        xidl_rust_axum::reqwest::header::ACCEPT,
        xidl_rust_axum::reqwest::header::HeaderValue::from_str("text/event-stream")
        .map_err(|err|xidl_rust_axum::Error::new(400,format!("{err:?}")))?,
        );
        xidl_rust_axum::stream::open_sse::<String>(self.client.http(),req).await
    }
}
