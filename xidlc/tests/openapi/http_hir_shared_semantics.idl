#pragma xidlc package = "reporting"
#pragma xidlc openapi version = "2026.04"
#pragma xidlc service "https://api.example.com" "production"

@http_bearer
interface ReportApi {
  @get(path = "/reports/{id}{?lang}")
  string get_report(
    @path @rename("id") string id,
    @query @rename("lang") @optional string lang,
    @header @rename("X-Trace-Id") string trace_id
  );

  @server_stream
  @get(path = "/reports/{id}/events")
  string watch_report(@path @rename("id") string id);
};
