#progma xidlc package xidlc
#progma xidlc version v1.0.0

interface HttpEdgeCasesService {
    @head(path = " //v1//health/ ")
    void health(
        @query("trace_id") string trace
    );

    @get(path = "//v1//users/{id}//")
    @path("/v2/users/{id}/")
    string get_user(
        @path("id") uint32 uid,
        @query("lang") string locale
    );

    @get(path = "/orders/{order_id}/items/{item_id}")
    string get_item(
        uint32 order_id,
        uint32 item_id
    );

    string lookup(
        @query string keyword,
        @query("limit") uint32 page_size
    );
};
