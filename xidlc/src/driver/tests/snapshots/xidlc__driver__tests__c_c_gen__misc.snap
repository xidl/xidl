}

XcdrBufferResult Foo_serialize(Foo const * self, XcdrBuffer buf) {
    uint8_t * ptr = buf.ptr;
    size_t len = buf.len;
    FfiCdrSerializer serializer = cdr_serializer_new(ptr, len);
    XcdrFfiError err = Ok;
    err = cdr_serializer_write_i32(&serializer, "self->value");
    if (err != Ok) {
        return (XcdrBufferResult){
            err, cdr_serializer_position(&serializer)
        };
    }

    {
        size_t before = cdr_serializer_position(&serializer);
        XcdrBufferResult child = FooSeq_serialize(
        &self->chain, (XcdrBuffer){
            .ptr = ptr + before, .len = len - before, .pos = 0
        });
        if (child.err != Ok) {
            return (XcdrBufferResult){
                child.err, before + child.used
            };
        }
        serializer.pos = before + child.used;
    }

    return (XcdrBufferResult){
        Ok, cdr_serializer_position(&serializer)
    };
}

XcdrBufferResult Foo_deserialize(Foo * self, XcdrConstBuffer buf) {
    const uint8_t * ptr = buf.ptr;
    size_t len = buf.len;
    FfiCdrDeserializer deserializer = cdr_deserializer_new(ptr, len);
    XcdrFfiError err = Ok;
    err = cdr_deserializer_read_i32_le(&deserializer, "self->value");
    if (err != Ok) {
        return (XcdrBufferResult){
            err, cdr_deserializer_position(&deserializer)
        };
    }

    {
        size_t before = cdr_deserializer_position(&deserializer);
        XcdrBufferResult child = FooSeq_deserialize(
        &self->chain, (XcdrConstBuffer){
            .ptr = ptr + before, .len = len - before, .pos = 0
        });
        if (child.err != Ok) {
            return (XcdrBufferResult){
                child.err, before + child.used
            };
        }
        deserializer.pos = before + child.used;
    }

    return (XcdrBufferResult){
        Ok, cdr_deserializer_position(&deserializer)
    };
}

XcdrBufferResult Foo_serialize(Foo const * self, XcdrBuffer buf) {
    uint8_t * ptr = buf.ptr;
    size_t len = buf.len;
    FfiCdrSerializer serializer = cdr_serializer_new(ptr, len);
    XcdrFfiError err = Ok;
    err = cdr_serializer_write_f64(&serializer, "self->d_mem");
    if (err != Ok) {
        return (XcdrBufferResult){
            err, cdr_serializer_position(&serializer)
        };
    }

    {
        size_t before = cdr_serializer_position(&serializer);
        XcdrBufferResult child = BarSeq_serialize(
        &self->nested, (XcdrBuffer){
            .ptr = ptr + before, .len = len - before, .pos = 0
        });
        if (child.err != Ok) {
            return (XcdrBufferResult){
                child.err, before + child.used
            };
        }
        serializer.pos = before + child.used;
    }

    return (XcdrBufferResult){
        Ok, cdr_serializer_position(&serializer)
    };
}

XcdrBufferResult Foo_deserialize(Foo * self, XcdrConstBuffer buf) {
    const uint8_t * ptr = buf.ptr;
    size_t len = buf.len;
    FfiCdrDeserializer deserializer = cdr_deserializer_new(ptr, len);
    XcdrFfiError err = Ok;
    err = cdr_deserializer_read_f64_le(&deserializer, "self->d_mem");
    if (err != Ok) {
        return (XcdrBufferResult){
            err, cdr_deserializer_position(&deserializer)
        };
    }

    {
        size_t before = cdr_deserializer_position(&deserializer);
        XcdrBufferResult child = BarSeq_deserialize(
        &self->nested, (XcdrConstBuffer){
            .ptr = ptr + before, .len = len - before, .pos = 0
        });
        if (child.err != Ok) {
            return (XcdrBufferResult){
                child.err, before + child.used
            };
        }
        deserializer.pos = before + child.used;
    }

    return (XcdrBufferResult){
        Ok, cdr_deserializer_position(&deserializer)
    };
}

XcdrBufferResult Bar_serialize(Bar const * self, XcdrBuffer buf) {
    uint8_t * ptr = buf.ptr;
    size_t len = buf.len;
    FfiCdrSerializer serializer = cdr_serializer_new(ptr, len);
    XcdrFfiError err = Ok;
    err = cdr_serializer_write_i32(&serializer, "self->_d");
    if (err != Ok) {
        return (XcdrBufferResult){
            err, cdr_serializer_position(&serializer)
        };
    }

    switch (self->_d) {
        case 0:

            err = cdr_serializer_write_i32(&serializer, "self->_u.l_mem");
            if (err != Ok) {
                return (XcdrBufferResult){
                    err, cdr_serializer_position(&serializer)
                };
            }

            break;
        case 1:

            {
                size_t before = cdr_serializer_position(&serializer);
                XcdrBufferResult child = Foo_serialize(
                &self->_u.s_mem, (XcdrBuffer){
                    .ptr = ptr + before, .len = len - before, .pos = 0
                });
                if (child.err != Ok) {
                    return (XcdrBufferResult){
                        child.err, before + child.used
                    };
                }
                serializer.pos = before + child.used;
            }

            break;
    }
    return (XcdrBufferResult){
        Ok, cdr_serializer_position(&serializer)
