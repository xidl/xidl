#include "bitmask_def.h"
A A_new(void) {
  A value;
  A_init(&value);
  return value;
}

void A_init(A* self) {
  *self = (A)0;
}

unsigned int A_bits(A const* self) {
  return (unsigned int)(*self);
}

bool A_is_empty(A const* self) {
  return A_bits(self) == 0u;
}

bool A_is_all(A const* self) {
  return (A_bits(self) & (0)) == (0);
}

bool A_contains(A const* self, A other) {
  return (A_bits(self) & (unsigned int)other) == (unsigned int)other;
}

bool A_intersects(A const* self, A other) {
  return (A_bits(self) & (unsigned int)other) != 0u;
}

void A_insert(A* self, A other) {
  *self = (A)(A_bits(self) | (unsigned int)other);
}

void A_remove(A* self, A other) {
  *self = (A)( A_bits(self) & ~(unsigned int)other);
}

void A_toggle(A* self, A other) {
  *self = (A)(A_bits(self) ^ (unsigned int)other);
}

void A_set(A* self, A other, bool value) {
  if (value) {
    A_insert(self, other);
  } else {
    A_remove(self, other);
  }
}
