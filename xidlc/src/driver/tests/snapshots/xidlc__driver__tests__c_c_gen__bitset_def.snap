A A_new(void){
    A value;
    A_init(&value);
    return value;
}

void A_init(A * self){
    * self = (A){
        0
    };
}

unsigned int A_bits(A const * self){
    unsigned int bits = 0u;
    if(self->a){
        bits|=(1u<<(1));
    }

    if(self->a){
        bits|=(1u<<(1));
    }

    if(self->b){
        bits|=(1u<<(1));
    }

    if(self->c){
        bits|=(1u<<(1));
    }

    return bits;
}

bool A_is_empty(A const * self){
    return A_bits(self) == 0u;
}

bool A_is_all(A const * self){
    return(A_bits(self)&((1u<<(1))|(1u<<(1))|(1u<<(1))|(1u<<(1)))) == ((1u<<(1))|(1u<<(1))|(1u<<(1))|(1u<<(1)));
}

bool A_contains(A const * self, A const * other){
    unsigned int other_bits = A_bits(other);
    return(A_bits(self)&other_bits) == other_bits;
}

bool A_intersects(A const * self, A const * other){
    return(A_bits(self)&A_bits(other)) != 0u;
}

void A_insert(A * self, A const * other){
    unsigned int other_bits = A_bits(other);
    if(other_bits&(1u<<(1))){
        self->a = 1;
    }

    if(other_bits&(1u<<(1))){
        self->a = 1;
    }

    if(other_bits&(1u<<(1))){
        self->b = 1;
    }

    if(other_bits&(1u<<(1))){
        self->c = 1;
    }
}

void A_remove(A * self, A const * other){
    unsigned int other_bits = A_bits(other);
    if(other_bits&(1u<<(1))){
        self->a = 0;
    }

    if(other_bits&(1u<<(1))){
        self->a = 0;
    }

    if(other_bits&(1u<<(1))){
        self->b = 0;
    }

    if(other_bits&(1u<<(1))){
        self->c = 0;
    }
}

void A_toggle(A * self, A const * other){
    unsigned int other_bits = A_bits(other);
    if(other_bits&(1u<<(1))){
        self->a = self->a?0:1;
    }

    if(other_bits&(1u<<(1))){
        self->a = self->a?0:1;
    }

    if(other_bits&(1u<<(1))){
        self->b = self->b?0:1;
    }

    if(other_bits&(1u<<(1))){
        self->c = self->c?0:1;
    }
}

void A_set(A * self, A const * other, bool value){
    if(value){
        A_insert(self, other);

    }else{
        A_remove(self, other);
    }
}
