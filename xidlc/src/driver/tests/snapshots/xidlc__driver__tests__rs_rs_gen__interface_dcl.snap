pub struct A_Return {
    tag: i32,
    data: A_ReturnData,
}


union A_ReturnData {

    unknownOp: core::mem::ManuallyDrop<Box<UnknownOperation>>,

    opA: core::mem::ManuallyDrop<Box<A_opA_Result>>,

}

impl Drop for A_Return {
    fn drop(&mut self) {
        match self.tag {
            
                _ => {
                    unsafe {
                        core::mem::ManuallyDrop::drop(&mut self.data.unknownOp);
                    }
                }
            
                A_opA_Hash => {
                    unsafe {
                        core::mem::ManuallyDrop::drop(&mut self.data.opA);
                    }
                }
            
        }
    }
}

impl A_Return {
