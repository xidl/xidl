        xidl_xcdr::SerializeKind::Cdr;

    
        pub fn new_unknownOp(value: Box<UnknownOperation>) -> Self {
            
            
                
            
            Self {
                tag: i32::default(),
                data: A_ReturnData {
                    unknownOp: core::mem::ManuallyDrop::new(value),
                }
            }
        }

        pub fn is_unknownOp(&self) -> bool {
            matches!(self.tag, _)
        }
    
        pub fn new_opA(value: Box<A_opA_Result>) -> Self {
            
            
            Self {
                tag: A_opA_Hash,
                data: A_ReturnData {
                    opA: core::mem::ManuallyDrop::new(value),
                }
            }
        }

        pub fn is_opA(&self) -> bool {
            matches!(self.tag, A_opA_Hash)
        }
    


    pub fn tag(&self) -> &i32 {
        &self.tag
    }
}

