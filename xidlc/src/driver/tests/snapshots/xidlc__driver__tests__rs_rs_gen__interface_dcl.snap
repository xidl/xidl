    data: A_CallData,
}


union A_CallData {
    unknownOp: core::mem::ManuallyDrop<dds::rpc::UnknownOperation>,
    opA: core::mem::ManuallyDrop<A_opA_In>,
}

impl Drop for A_Call {
    fn drop(&mut self) {
        match self.tag {
            
                _ => {
                    unsafe {
                        core::mem::ManuallyDrop::drop(&mut self.data.unknownOp);
                    }
                }
            
                A_opA_Hash => {
                    unsafe {
                        core::mem::ManuallyDrop::drop(&mut self.data.opA);
                    }
                }
            
        }
    }
}

impl A_Call {
    
        pub const SERIALIZE_KIND: xidl_xcdr::SerializeKind =
            xidl_xcdr::SerializeKind::Cdr;
    

    
        pub fn new_unknownOp(value: dds::rpc::UnknownOperation) -> Self {
            
            
                
            
            Self {
                tag: i32::default(),
                data: A_CallData {
                    unknownOp: core::mem::ManuallyDrop::new(value),
                }
            }
        }

        pub fn is_unknownOp(&self) -> bool {
            matches!(self.tag, _)
        }

        pub unsafe fn as_unknownOp(&self) -> &dds::rpc::UnknownOperation {
            unsafe { &self.data.unknownOp }
        }

        pub unsafe fn as_unknownOp_mut(&mut self) -> &mut dds::rpc::UnknownOperation {
            unsafe { &mut self.data.unknownOp }
        }

        pub unsafe fn into_unknownOp(self) -> dds::rpc::UnknownOperation {
            unsafe {
                let mut forget = core::mem::ManuallyDrop::new(self);
                core::mem::ManuallyDrop::take(&mut forget.data.unknownOp)
            }
        }
    
        pub fn new_opA(value: A_opA_In) -> Self {
            
            
            Self {
                tag: A_opA_Hash,
                data: A_CallData {
                    opA: core::mem::ManuallyDrop::new(value),
                }
            }
        }

        pub fn is_opA(&self) -> bool {
            matches!(self.tag, A_opA_Hash)
        }

        pub unsafe fn as_opA(&self) -> &A_opA_In {
            unsafe { &self.data.opA }
        }

        pub unsafe fn as_opA_mut(&mut self) -> &mut A_opA_In {
            unsafe { &mut self.data.opA }
        }

        pub unsafe fn into_opA(self) -> A_opA_In {
            unsafe {
                let mut forget = core::mem::ManuallyDrop::new(self);
                core::mem::ManuallyDrop::take(&mut forget.data.opA)
            }
        }
    


    pub fn tag(&self) -> &i32 {
        &self.tag
    }
}






impl xidl_xcdr::XcdrSerialize for A_Call {
    fn serialize_kind(&self) -> xidl_xcdr::SerializeKind {
        Self::SERIALIZE_KIND
    }

    fn serialize_with<S: xidl_xcdr::XcdrSerializer + ?Sized>(
        &self,
        serializer: &mut S,
    ) -> xidl_xcdr::error::XcdrResult<()> {
        serializer.begin_struct_with_kind(Self::SERIALIZE_KIND)?;
        serializer.begin_field(xidl_xcdr::FieldId(0), false, 0)?;
        xidl_xcdr::XcdrSerialize::serialize_with(&self.tag, serializer)?;
        serializer.end_field()?;
        match self.tag {
            
                _ => {
                    let value = unsafe { self.data.unknownOp.as_ref() };
                    serializer.begin_field(xidl_xcdr::FieldId(1u32), false, 0)?;
                    xidl_xcdr::XcdrSerialize::serialize_with(value, serializer)?;
                    serializer.end_field()?;
                },
            
                A_opA_Hash => {
                    let value = unsafe { self.data.opA.as_ref() };
                    serializer.begin_field(xidl_xcdr::FieldId(2u32), false, 0)?;
                    xidl_xcdr::XcdrSerialize::serialize_with(value, serializer)?;
                    serializer.end_field()?;
                },
            
            
        }
        serializer.end_struct()?;
        Ok(())
    }
}



impl xidl_xcdr::XcdrDeserialize for A_Call {
    fn deserialize<D: xidl_xcdr::XcdrDeserializer + ?Sized>(
        deserializer: &mut D,
    ) -> xidl_xcdr::error::XcdrResult<Self> {
        let tag = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;
        let data = match tag {
            
                _ => {
                    A_CallData {
                        unknownOp: core::mem::ManuallyDrop::new(xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?),
                    }
                }
            
                A_opA_Hash => {
                    A_CallData {
                        opA: core::mem::ManuallyDrop::new(xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?),
                    }
                }
            
            
        };
        Ok(Self { tag, data } )
    }
}


pub struct A_Request {

    pub header: dds::rpc::RequestHeader,
    pub data: A_Call,
}

impl A_Request {
    
    pub const SERIALIZE_KIND: xidl_xcdr::SerializeKind =
        xidl_xcdr::SerializeKind::Cdr;
    
}


impl xidl_xcdr::XcdrSerialize for A_Request {
    fn serialize_kind(&self) -> xidl_xcdr::SerializeKind {
        Self::SERIALIZE_KIND
    }

    fn serialize_with<S: xidl_xcdr::XcdrSerializer + ?Sized>(
        &self,
        serializer: &mut S,
    ) -> xidl_xcdr::error::XcdrResult<()> {
        serializer.begin_struct_with_kind(Self::SERIALIZE_KIND)?;



        serializer.begin_field(xidl_xcdr::FieldId(1u32), false, 0)?;

        xidl_xcdr::XcdrSerialize::serialize_with(&self.header, serializer)?;
        serializer.end_field()?;


        serializer.begin_field(xidl_xcdr::FieldId(2u32), false, 0)?;

        xidl_xcdr::XcdrSerialize::serialize_with(&self.data, serializer)?;
        serializer.end_field()?;

        serializer.end_struct()?;
        Ok(())
    }
}



impl xidl_xcdr::XcdrDeserialize for A_Request {
    fn deserialize<D: xidl_xcdr::XcdrDeserializer + ?Sized>(
        deserializer: &mut D,
    ) -> xidl_xcdr::error::XcdrResult<Self> {


        let header = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;

        let data = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;

        Ok(Self {


            header,

            data,

        })
    }
}


