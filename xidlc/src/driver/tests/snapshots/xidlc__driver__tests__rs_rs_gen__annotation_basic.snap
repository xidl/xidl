    pub data: Box<I_Call>,

}

impl I_Request {
    pub const SERIALIZE_KIND: xidl_xcdr::SerializeKind =
        xidl_xcdr::SerializeKind::Cdr;
}

impl xidl_xcdr::XcdrSerialize for I_Request {
    fn serialize_kind(&self) -> xidl_xcdr::SerializeKind {
        Self::SERIALIZE_KIND
    }

    fn serialize_with<S: xidl_xcdr::XcdrSerializer + ?Sized>(
        &self,
        serializer: &mut S,
    ) -> xidl_xcdr::error::XcdrResult<()> {
        serializer.begin_struct()?;


        serializer.begin_field(xidl_xcdr::FieldId(1u32), false, 0)?;
        xidl_xcdr::XcdrSerialize::serialize_with(&self.header, serializer)?;
        serializer.end_field()?;

        serializer.begin_field(xidl_xcdr::FieldId(2u32), false, 0)?;
        xidl_xcdr::XcdrSerialize::serialize_with(&self.data, serializer)?;
        serializer.end_field()?;

        serializer.end_struct()?;
        Ok(())
    }
}

impl xidl_xcdr::XcdrDeserialize for I_Request {
    fn deserialize<D: xidl_xcdr::XcdrDeserializer + ?Sized>(
        deserializer: &mut D,
    ) -> xidl_xcdr::error::XcdrResult<Self> {


        let header = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;

        let data = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;

        Ok(Self {


            header,

            data,

        })
    }
}
pub struct I_Return {
    pub _d: i32,

    pub unknownOp: Option<Box<UnknownOperation>>,

    pub ping: Option<Box<I_ping_Result>>,

    pub get_attribute_value: Option<Box<I_get_attribute_value_Result>>,

    pub set_attribute_value: Option<Box<I_set_attribute_value_Result>>,

}

impl xidl_xcdr::XcdrSerialize for I_Return {
    fn serialize_with<S: xidl_xcdr::XcdrSerializer + ?Sized>(
        &self,
        serializer: &mut S,
    ) -> xidl_xcdr::error::XcdrResult<()> {
        serializer.begin_struct()?;
        serializer.begin_field(xidl_xcdr::FieldId(0), false, 0)?;
        xidl_xcdr::XcdrSerialize::serialize_with(&self._d, serializer)?;
        serializer.end_field()?;
        match self._d {

            _ => {
                let value = self.unknownOp.as_ref().ok_or_else(|| {
                    xidl_xcdr::error::XcdrError::Message(
                        "union member is not set for discriminator".to_string(),
                    )
                })?;
                serializer.begin_field(xidl_xcdr::FieldId(1), false, 0)?;
                xidl_xcdr::XcdrSerialize::serialize_with(value, serializer)?;
                serializer.end_field()?;
            }

            I_ping_Hash => {
                let value = self.ping.as_ref().ok_or_else(|| {
                    xidl_xcdr::error::XcdrError::Message(
                        "union member is not set for discriminator".to_string(),
                    )
                })?;
                serializer.begin_field(xidl_xcdr::FieldId(1), false, 0)?;
                xidl_xcdr::XcdrSerialize::serialize_with(value, serializer)?;
                serializer.end_field()?;
            }

            I_get_attribute_value_Hash => {
                let value = self.get_attribute_value.as_ref().ok_or_else(|| {
                    xidl_xcdr::error::XcdrError::Message(
                        "union member is not set for discriminator".to_string(),
                    )
                })?;
                serializer.begin_field(xidl_xcdr::FieldId(1), false, 0)?;
                xidl_xcdr::XcdrSerialize::serialize_with(value, serializer)?;
                serializer.end_field()?;
            }

            I_set_attribute_value_Hash => {
                let value = self.set_attribute_value.as_ref().ok_or_else(|| {
                    xidl_xcdr::error::XcdrError::Message(
                        "union member is not set for discriminator".to_string(),
                    )
                })?;
                serializer.begin_field(xidl_xcdr::FieldId(1), false, 0)?;
                xidl_xcdr::XcdrSerialize::serialize_with(value, serializer)?;
                serializer.end_field()?;
            }


        }
        serializer.end_struct()?;
        Ok(())
    }
}

impl xidl_xcdr::XcdrDeserialize for I_Return {
    fn deserialize<D: xidl_xcdr::XcdrDeserializer + ?Sized>(
        deserializer: &mut D,
    ) -> xidl_xcdr::error::XcdrResult<Self> {
        let _d = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;
        let mut out = Self {
            _d,

            unknownOp: None,

            ping: None,

            get_attribute_value: None,

            set_attribute_value: None,

        };
        match out._d {

            _ => {
                out.unknownOp = Some(xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?);
            }

            I_ping_Hash => {
                out.ping = Some(xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?);
            }

            I_get_attribute_value_Hash => {
                out.get_attribute_value = Some(xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?);
            }

            I_set_attribute_value_Hash => {
                out.set_attribute_value = Some(xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?);
            }


        }
        Ok(out)
    }
}
