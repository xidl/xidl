BM BM_new(void) {
  BM value;
  BM_init(&value);
  return value;
}

void BM_init(BM* self) {
  *self = (BM)0;
}

unsigned int BM_bits(BM const* self) {
  return (unsigned int)(*self);
}

bool BM_is_empty(BM const* self) {
  return BM_bits(self) == 0u;
}

bool BM_is_all(BM const* self) {
  return (BM_bits(self) & (A | B)) == (A | B);
}

bool BM_contains(BM const* self, BM other) {
  return (BM_bits(self) & (unsigned int)other) == (unsigned int)other;
}

bool BM_intersects(BM const* self, BM other) {
  return (BM_bits(self) & (unsigned int)other) != 0u;
}

void BM_insert(BM* self, BM other) {
  *self = (BM)(BM_bits(self) | (unsigned int)other);
}

void BM_remove(BM* self, BM other) {
  *self = (BM)( BM_bits(self) & ~(unsigned int)other);
}

void BM_toggle(BM* self, BM other) {
  *self = (BM)(BM_bits(self) ^ (unsigned int)other);
}

void BM_set(BM* self, BM other, bool value) {
  if (value) {
    BM_insert(self, other);
  } else {
    BM_remove(self, other);
  }
}
