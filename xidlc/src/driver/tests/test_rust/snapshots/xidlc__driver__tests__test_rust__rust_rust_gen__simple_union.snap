#[derive(Debug,Clone,Copy,PartialEq,Eq)]
pub enum Tag{
    A,
    B
}

pub struct SimpleUnion{
    tag:Tag,
    data:SimpleUnionData,
}

union SimpleUnionData{
    a:core::mem::ManuallyDrop<int>,
    b:core::mem::ManuallyDrop<int>,
}

impl Drop for SimpleUnion{
    fn drop(&mut self){
        match self.tag{
            A => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.a);
                }
            }
            B => {
                unsafe{
                    core::mem::ManuallyDrop::drop(&mut self.data.b);
                }
            }
        }
    }
}

impl SimpleUnion{
    pub fn new_a(value:int)->Self{
        Self{
            tag:A,
            data:SimpleUnionData{
                a:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_a(&self)->bool{
        matches!(self.tag,A)
    }

    pub fn as_a(&self)->&int{
        debug_assert!(self.is_a());
        unsafe{
            &self.data.a
        }
    }

    pub fn as_a_mut(&mut self)->&mut int{
        debug_assert!(self.is_a());
        unsafe{
            &mut self.data.a
        }
    }

    pub fn into_a(self)->int{
        debug_assert!(self.is_a());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.a)
        }
    }

    pub fn new_b(value:int)->Self{
        Self{
            tag:B,
            data:SimpleUnionData{
                b:core::mem::ManuallyDrop::new(value),
            }
        }
    }

    pub fn is_b(&self)->bool{
        matches!(self.tag,B)
    }

    pub fn as_b(&self)->&int{
        debug_assert!(self.is_b());
        unsafe{
            &self.data.b
        }
    }

    pub fn as_b_mut(&mut self)->&mut int{
        debug_assert!(self.is_b());
        unsafe{
            &mut self.data.b
        }
    }

    pub fn into_b(self)->int{
        debug_assert!(self.is_b());
        unsafe{
            let mut forget = core::mem::ManuallyDrop::new(self);
            core::mem::ManuallyDrop::take(&mut forget.data.b)
        }
    }

    pub fn tag(&self)->&Tag{
        &self.tag
    }
}
