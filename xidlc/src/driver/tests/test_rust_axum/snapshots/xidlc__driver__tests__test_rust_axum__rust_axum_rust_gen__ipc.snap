                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }

    pub async fn create_simple(&self,local_addr:String,remote_port:u16)->Result<CreateSimpleResponse,xidl_rust_axum::Error>{
        let path = "/api/v1/simple".to_string();
        let url = self.client.url(&path);
        let req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::POST,url);
        let body = HttpServiceCreateSimpleBody{
            local_addr,
            remote_port,
        };
        let req = req.json(&body);
        let resp = req
        .send()
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<CreateSimpleResponse>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }

    pub async fn stop_simple(&self,id:u32)->Result<(),xidl_rust_axum::Error>{
        let path = "/api/v1/simple/{id}".to_string();
        let path = path.replace("{{id}}",&id.to_string());
        let url = self.client.url(&path);
        let req = self
        .client
        .http()
        .request(xidl_rust_axum::reqwest::Method::DELETE,url);
        let resp = req
        .send()
        .await
        .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))?;
        if resp.status().is_success(){
            resp.json::<()>()
            .await
            .map_err(|err|xidl_rust_axum::Error::new(500,err.to_string()))
        }else{
            let status = resp.status();
            let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
            let err = match body{
                Some(body) => xidl_rust_axum::Error::new(body.code,body.msg),
                None => xidl_rust_axum::Error::new(500,format!("http error: {}",status.as_u16())),

            };
            Err(err)
        }
    }
