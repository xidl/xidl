        struct __Visitor;

        impl<'de> serde::de::Visitor<'de> for __Visitor {
            type Value = {{ ident }};

            fn expecting(&self, formatter: &mut core::fmt::Formatter) -> core::fmt::Result {
                formatter.write_str("externally tagged union {{ ident }}")
            }

            fn visit_enum<A>(self, data: A) -> Result<Self::Value, A::Error>
            where
                A: serde::de::EnumAccess<'de>,
            {
                let (variant, variant_access) = data.variant::<__Variant>()?;
                match variant {
                    {% for case in cases %}
                        __Variant::__Case{{ loop.index0 }} => {
                            struct __CaseVisitor;

                            impl<'de> serde::de::Visitor<'de> for __CaseVisitor {
                                type Value = {{ case.type }};

                                fn expecting(
                                    &self,
                                    formatter: &mut core::fmt::Formatter,
                                ) -> core::fmt::Result {
