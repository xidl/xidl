{%- for line in doc %}
    /// {{ line }}
{%- endfor %}
{% for attr in rust_attrs %}
    #[{{ attr }}]
{% endfor %}
{% if derive and derive | length > 0 %}
    #[derive({{ derive | join(", ") }})]
{% endif %}
pub struct {{ ident }} {
    pub value: u32,
}

impl {{ ident }} {
    {% for value in values %}
        {%- for line in value.doc %}
            /// {{ line }}
        {%- endfor %}
        {% for attr in value.rust_attrs %}
            #[{{ attr }}]
        {% endfor %}
        pub const {{ value.name }}: u32 = 1u32 << {{ value.index }};
    {% endfor %}
}

{% if opt.enable_serialize %}
    impl xidl_xcdr::XcdrSerialize for {{ ident }} {
        fn serialize_with<S: xidl_xcdr::XcdrSerializer + ?Sized>(
        &self,
        serializer: &mut S,
        ) -> xidl_xcdr::error::XcdrResult<()> {
            xidl_xcdr::XcdrSerialize::serialize_with(&self.value, serializer)
        }
    }
{% endif %}

{% if opt.enable_deserialize %}
    impl xidl_xcdr::XcdrDeserialize for {{ ident }} {
        fn deserialize<D: xidl_xcdr::XcdrDeserializer + ?Sized>(
        deserializer: &mut D,
        ) -> xidl_xcdr::error::XcdrResult<Self> {
            let value = xidl_xcdr::XcdrDeserialize::deserialize(deserializer)?;
            Ok(Self { value })
        }
    }
{% endif %}
