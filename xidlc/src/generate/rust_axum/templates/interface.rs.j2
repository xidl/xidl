{% if rust_attrs and rust_attrs | length > 0 %}
    {% for attr in rust_attrs %}
        #[{{ attr }}]
    {% endfor %}
{%- endif %}
#[async_trait::async_trait]
pub trait {{ ident }} {
    {% for method in methods %}
        {% if method.rust_attrs and method.rust_attrs | length > 0 %}
            {% for attr in method.rust_attrs %}
                #[{{ attr }}]
            {% endfor %}
        {% endif %}
        {% if method.deprecated -%}
            #[deprecated{% if method.deprecated_note %}(note = "{{ method.deprecated_note }}"){% endif %}]
        {%- endif %}
        async fn {{ method.name }}(
        &self{% if method.is_server_stream or method.is_client_stream or method.is_bidi_stream %},
        req: ::xidl_rust_axum::Request<{{ method.request_payload_ty }}>{% elif method.server_params | length > 0 %},
        {{ method.server_params | join(", ") }}{% endif %}
        ) -> ::xidl_rust_axum::Result<{% if method.is_server_stream %}xidl_rust_axum::stream::SseStream<{{ method.response_ty }}>{% elif method.is_bidi_stream %}(){% else %}{{ method.response_ty }}{% endif %}>;
    {% endfor %}
}

{% set module = inbound_transport %}
{% include 'interface/transport_module.rs.j2' %}

{% set module = outbound_transport %}
{% include 'interface/transport_module.rs.j2' %}

{% for method in methods %}
    {% if method.path_params | length > 0 and opt.enable_server %}
        #[derive(::serde::Deserialize)]
        struct {{ method.struct_prefix }}Path {
            {% for param in method.path_params %}
                {% if param.serde_rename is defined and param.serde_rename %}
                    #[serde(rename = "{{ param.serde_rename }}")]
                {% endif %}
                {{ param.name }}: {{ param.ty }},
            {% endfor %}
        }

    {% endif %}
    {% if method.query_params | length > 0 %}
        #[derive(::serde::Serialize, ::core::default::Default)]
        struct {{ method.struct_prefix }}RequestOutQuery {
            {% for param in method.query_params %}
                {% if param.serde_rename is defined and param.serde_rename %}
                    #[serde(rename = "{{ param.serde_rename }}")]
                {% endif %}
                #[serde(default)]
                {{ param.name }}: {{ param.out_ty }},
            {% endfor %}
        }

        #[derive(::serde::Deserialize, ::core::default::Default)]
        struct {{ method.struct_prefix }}RequestInQuery {
            {% for param in method.query_params %}
                {% if param.serde_rename is defined and param.serde_rename %}
                    #[serde(rename = "{{ param.serde_rename }}")]
                {% endif %}
                #[serde(default)]
                {{ param.name }}: {{ param.in_ty }},
            {% endfor %}
        }

    {% endif %}
    {% if method.body_params | length > 0 %}
        {% if method.request_body_flatten %}
            type {{ method.struct_prefix }}RequestOutBody = {{ method.body_params[0].out_ty }};
            type {{ method.struct_prefix }}RequestInBody = {{ method.body_params[0].in_ty }};
        {% else %}
            #[derive(::serde::Serialize)]
            struct {{ method.struct_prefix }}RequestOutBody {
                {% for param in method.body_params %}
                    {% if param.serde_rename is defined and param.serde_rename %}
                        #[serde(rename = "{{ param.serde_rename }}")]
                    {% endif %}
                    {% if param.optional %}
                        #[serde(default)]
                    {% else %}
                        #[serde(default)]
                    {% endif %}
                    {{ param.name }}: {{ param.out_ty }},
                {% endfor %}
            }

            #[derive(::serde::Deserialize)]
            struct {{ method.struct_prefix }}RequestInBody {
                {% for param in method.body_params %}
                    {% if param.serde_rename is defined and param.serde_rename %}
                        #[serde(rename = "{{ param.serde_rename }}")]
                    {% endif %}
                    {% if param.optional %}
                        #[serde(default)]
                    {% endif %}
                    {{ param.name }}: {{ param.in_ty }},
                {% endfor %}
            }
        {% endif %}

    {% endif %}
    {% if method.request_struct is defined and method.request_struct and (method.is_server_stream or method.is_client_stream or method.is_bidi_stream) %}
        #[derive({% if opt.enable_client %}::serde::Serialize{% if opt.enable_server %}, {% endif %}{% endif %}{% if opt.enable_server %}::serde::Deserialize{% endif %})]
        pub struct {{ method.request_struct }} {
            {% for param in method.request_params %}
                pub {{ param.name }}: {{ param.ty }},
            {% endfor %}
            {% if method.auth_in_request_struct %}
                pub xidl_auth: {{ method.auth_ty }},
            {% endif %}
        }

    {% endif %}
    {% if method.request_struct is defined and method.request_struct and not method.is_server_stream and not method.is_client_stream and not method.is_bidi_stream %}
        #[derive(::serde::Deserialize)]
        struct {{ method.request_struct }} {
            {% for param in method.request_params %}
                {{ param.name }}: {{ param.in_ty }},
            {% endfor %}
        }

        #[allow(clippy::manual_async_fn)]
        impl<S> ::xidl_rust_axum::axum::extract::FromRequest<S> for {{ method.request_struct }}
        where
        S: Send + Sync,
        {
            type Rejection = ::xidl_rust_axum::Error;

            fn from_request(
            req: ::xidl_rust_axum::axum::extract::Request,
            state: &S,
            ) -> impl ::core::future::Future<Output = Result<Self, Self::Rejection>> + Send {
                async move {
                    let (mut parts, body) = req.into_parts();
                    {% if method.path_params | length > 0 %}
                        let ::xidl_rust_axum::axum::extract::Path(path) =
                        <::xidl_rust_axum::axum::extract::Path<{{ method.struct_prefix }}Path> as ::xidl_rust_axum::axum::extract::FromRequestParts<S>>::from_request_parts(&mut parts, state)
                        .await
                        .map_err(|err| ::xidl_rust_axum::Error::new(400, err.to_string()))?;
                        let {{ method.struct_prefix }}Path {
                            {% for param in method.path_params %}
                                {{ param.name }},
                            {% endfor %}
                        } = path;
                    {% endif %}
                    {% if method.query_params | length > 0 %}
                        let ::xidl_rust_axum::axum::extract::Query(query) =
                        <::xidl_rust_axum::axum::extract::Query<{{ method.struct_prefix }}RequestInQuery> as ::xidl_rust_axum::axum::extract::FromRequestParts<S>>::from_request_parts(&mut parts, state)
                        .await
                        .map_err(|err| ::xidl_rust_axum::Error::new(400, err.to_string()))?;
                        let {{ method.struct_prefix }}RequestInQuery {
                            {% for param in method.query_params %}
                                {{ param.name }},
                            {% endfor %}
                        } = query;
                    {% endif %}
                    let headers = &parts.headers;
                    {% if method.header_params | length > 0 %}
                        {% for param in method.header_params %}
                            {% if param.header_is_multi %}
                                let mut {{ param.name }}: Vec<{{ param.header_item_ty }}> = Vec::new();
                                for header_value in headers.get_all("{{ param.wire_name }}").iter() {
                                    let header_str = header_value
                                    .to_str()
                                    .map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?;
                                    let parsed: {{ param.header_item_ty }} = {% if param.header_item_is_string %}header_str.to_string(){% elif param.header_item_is_primitive %}header_str.parse().map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% else %}::xidl_rust_axum::serde_json::from_str(header_str).map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% endif %};
                                    {{ param.name }}.push(parsed);
                                }
                                {% if param.optional %}
                                    let {{ param.name }} = if {{ param.name }}.is_empty() { None } else { Some({{ param.name }}) };
                                {% else %}
                                    let {{ param.name }}: {{ param.ty }} = if {{ param.name }}.is_empty() { ::core::default::Default::default() } else { {{ param.name }} };
                                {% endif %}
                            {% else %}
                                {% if param.optional %}
                                    let {{ param.name }}: {{ param.ty }} = match headers.get("{{ param.wire_name }}") {
                                        Some(header_value) => {
                                            let header_str = header_value
                                            .to_str()
                                            .map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?;
                                            Some({% if param.header_item_is_string %}header_str.to_string(){% elif param.header_item_is_primitive %}header_str.parse().map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% else %}::xidl_rust_axum::serde_json::from_str(header_str).map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% endif %})
                                        }
                                        None => None,
                                    };
                                {% else %}
                                    let {{ param.name }}: {{ param.ty }} = match headers.get("{{ param.wire_name }}") {
                                        Some(header_value) => {
                                            let header_str = header_value
                                            .to_str()
                                            .map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?;
                                            {% if param.header_item_is_string %}header_str.to_string(){% elif param.header_item_is_primitive %}header_str.parse().map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% else %}::xidl_rust_axum::serde_json::from_str(header_str).map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% endif %}
                                            }
                                            None => ::core::default::Default::default(),
                                        };
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                        {% if method.cookie_params | length > 0 %}
                            let mut cookie_map: ::std::collections::HashMap<String, Vec<String>> = ::std::collections::HashMap::new();
                            for header_value in headers.get_all("cookie").iter() {
                                let cookie_str = header_value
                                .to_str()
                                .map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?;
                                for part in cookie_str.split(';') {
                                    let part = part.trim();
                                    if part.is_empty() {
                                        continue;
                                    }
                                    let mut iter = part.splitn(2, '=');
                                    let name = iter.next().unwrap_or("").trim();
                                    if name.is_empty() {
                                        continue;
                                    }
                                    let value = iter.next().unwrap_or("").trim().to_string();
                                    cookie_map.entry(name.to_string()).or_default().push(value);
                                }
                            }
                            {% for param in method.cookie_params %}
                                {% if param.cookie_is_multi %}
                                    let mut {{ param.name }}: Vec<{{ param.cookie_item_ty }}> = Vec::new();
                                    if let Some(values) = cookie_map.get("{{ param.wire_name }}") {
                                        for value in values {
                                            let parsed: {{ param.cookie_item_ty }} = {% if param.cookie_item_is_string %}value.to_string(){% elif param.cookie_item_is_primitive %}value.parse().map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% else %}::xidl_rust_axum::serde_json::from_str(value).map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% endif %};
                                            {{ param.name }}.push(parsed);
                                        }
                                    }
                                    {% if param.optional %}
                                        let {{ param.name }} = if {{ param.name }}.is_empty() { None } else { Some({{ param.name }}) };
                                    {% else %}
                                        let {{ param.name }}: {{ param.ty }} = if {{ param.name }}.is_empty() { ::core::default::Default::default() } else { {{ param.name }} };
                                    {% endif %}
                                {% else %}
                                    {% if param.optional %}
                                        let {{ param.name }}: {{ param.ty }} = match cookie_map.get("{{ param.wire_name }}").and_then(|values| values.first()) {
                                            Some(value) => Some({% if param.cookie_item_is_string %}value.to_string(){% elif param.cookie_item_is_primitive %}value.parse().map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% else %}::xidl_rust_axum::serde_json::from_str(value).map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% endif %}),
                                            None => None,
                                        };
                                    {% else %}
                                        let {{ param.name }}: {{ param.ty }} = match cookie_map.get("{{ param.wire_name }}").and_then(|values| values.first()) {
                                            Some(value) => {% if param.cookie_item_is_string %}value.to_string(){% elif param.cookie_item_is_primitive %}value.parse().map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% else %}::xidl_rust_axum::serde_json::from_str(value).map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?{% endif %},
                                            None => ::core::default::Default::default(),
                                        };
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                        {% if method.body_params | length > 0 %}
                            if !::xidl_rust_axum::http::content_type_matches(headers, "{{ method.request_content_type }}") {
                                return Err(::xidl_rust_axum::Error::unsupported_media_type());
                            }
                            let body_bytes = ::xidl_rust_axum::axum::body::to_bytes(body, usize::MAX)
                            .await
                            .map_err(|err| ::xidl_rust_axum::Error::new(400, format!("{err:?}")))?;
                            let body: {{ method.struct_prefix }}RequestInBody = ::xidl_rust_axum::DeserializeFactory::new("{{ method.request_content_type }}")
                            .from_slice(&body_bytes)?;
                            {% if method.request_body_flatten %}
                                let {{ method.body_params[0].name }} = body;
                            {% else %}
                                let {{ method.struct_prefix }}RequestInBody {
                                    {% for param in method.body_params %}
                                        {{ param.name }},
                                    {% endfor %}
                                } = body;
                            {% endif %}
                        {% endif %}
                        Ok(Self {
                            {% for param in method.request_params %}
                                {{ param.name }},
                            {% endfor %}
                        })
                    }
                }
            }

        {% endif %}
        {% if method.auth_wrapper_struct %}
            pub struct {{ method.auth_wrapper_struct }} {
                pub xidl_auth: {{ method.auth_ty }},
                pub data: {% if method.is_client_stream %}xidl_rust_axum::stream::NdjsonStream<{{ method.request_item_ty }}>{% elif method.is_bidi_stream %}xidl_rust_axum::stream::BidiServerStream<{{ method.request_item_ty }}, {{ method.response_ty }}>{% endif %},
            }

        {% endif %}
        {% set response_body_count = method.response_body_params | length + (0 if method.return_is_unit else 1) %}
        {% if method.response_struct and response_body_count > 0 %}
            #[derive(::serde::Serialize)]
            struct {{ method.struct_prefix }}ResponseOutBody {
                {% if method.response_include_return %}
                    r#return: {{ method.ret_out_ty }},
                {% endif %}
                {% for param in method.response_body_params %}
                    {% if param.serde_rename is defined and param.serde_rename %}
                        #[serde(rename = "{{ param.serde_rename }}")]
                    {% endif %}
                    {{ param.name }}: {{ param.out_ty }},
                {% endfor %}
            }

            #[derive(::serde::Deserialize)]
            struct {{ method.struct_prefix }}ResponseInBody {
                {% if method.response_include_return %}
                    r#return: {{ method.ret_in_ty }},
                {% endif %}
                {% for param in method.response_body_params %}
                    {% if param.serde_rename is defined and param.serde_rename %}
                        #[serde(rename = "{{ param.serde_rename }}")]
                    {% endif %}
                    {{ param.name }}: {{ param.in_ty }},
                {% endfor %}
            }

        {% endif %}
        {% if method.response_struct is defined and method.response_struct %}
            {% if method.is_server_stream or method.is_client_stream or method.is_bidi_stream %}
                #[derive(::serde::Serialize, ::serde::Deserialize)]
            {% endif %}
            pub struct {{ method.response_struct }} {
                {% if method.response_include_return %}
                    pub r#return: {{ method.ret }},
                {% endif %}
                {% for param in method.response_params %}
                    {% if (method.is_server_stream or method.is_client_stream or method.is_bidi_stream) and param.serde_rename is defined and param.serde_rename %}
                        #[serde(rename = "{{ param.serde_rename }}")]
                    {% endif %}
                    pub {{ param.name }}: {{ param.ty }},
                {% endfor %}
            }

            {% if method.response_struct and response_body_count > 0 %}
                #[allow(clippy::useless_conversion)]
                impl From<{{ method.response_struct }}> for {{ method.struct_prefix }}ResponseOutBody {
                    fn from(value: {{ method.response_struct }}) -> Self {
                        Self {
                            {% if method.response_include_return %}
                                r#return: {{ method.ret_out_expr | replace("resp_value", "value.r#return") }},
                            {% endif %}
                            {% for param in method.response_body_params %}
                                {{ param.name }}: {{ param.field_out_expr }},
                            {% endfor %}
                        }
                    }
                }

                #[allow(clippy::useless_conversion)]
                impl From<{{ method.struct_prefix }}ResponseInBody> for {{ method.response_struct }} {
                    fn from(value: {{ method.struct_prefix }}ResponseInBody) -> Self {
                        Self {
                            {% if method.response_include_return %}
                                r#return: {{ method.ret_in_expr | replace("body", "value.r#return") }},
                            {% endif %}
                            {% for param in method.response_body_params %}
                                {{ param.name }}: {{ param.field_in_expr }},
                            {% endfor %}
                            {% for param in method.response_header_params %}
                                {{ param.name }}: ::core::default::Default::default(),
                            {% endfor %}
                            {% for param in method.response_cookie_params %}
                                {{ param.name }}: ::core::default::Default::default(),
                            {% endfor %}
                        }
                    }
                }
            {% endif %}

        {% endif %}
    {% endfor %}

    {% if opt.enable_server %}
        {% include 'interface/server.rs.j2' %}
    {% endif %}

    {% if opt.enable_client %}
        {% include 'interface/client.rs.j2' %}
    {% endif %}
