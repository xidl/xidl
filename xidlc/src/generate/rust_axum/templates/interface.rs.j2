                        };
                    {% endif %}
                    let body = xidl_rust_axum::serde_json::to_vec(&body)
                        .map_err(|err| xidl_rust_axum::Error::new(500, format!("{err:?}")))?;
                    req.headers_mut().insert(
                        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
                        xidl_rust_axum::reqwest::header::HeaderValue::from_str("{{ method.request_content_type }}")
                            .map_err(|err| xidl_rust_axum::Error::new(400, format!("{err:?}")))?,
                    );
                    *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
                {% endif %}
                {% if method.is_server_stream %}
                    xidl_rust_axum::stream::open_sse::<{{ method.response_ty }}>(self.client.http(), req).await
                {% elif not method.is_client_stream and not method.is_bidi_stream %}
                let resp = self
                    .client
                    .http()
                    .execute(req)
                    .await
                    .map_err(|err| xidl_rust_axum::Error::new(500, format!("{err:?}")))?;
                if resp.status().is_success() {
                    {% if method.response_is_empty %}
                        Ok(())
                    {% else %}
                        resp.json::<{{ method.response_ty }}>()
                        .await
                        .map_err(|err| xidl_rust_axum::Error::new(500, format!("{err:?}")))
                    {% endif %}
                } else {
                    let status = resp.status();
                    let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
                    Err(xidl_rust_axum::Error::from_http_response(status, body))
                }
                {% endif %}
            }
        {% endfor %}
    }
{% endif %}
