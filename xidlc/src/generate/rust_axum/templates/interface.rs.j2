#[async_trait::async_trait]
pub trait {{ ident }} {
    {% for method in methods %}
        async fn {{ method.name }}(
        &self,
        req: xidl_rust_axum::Request<{% if method.is_client_stream %}xidl_rust_axum::stream::NdjsonStream<{{ method.request_item_ty }}>{% else %}{{ method.request_ty }}{% endif %}>
        ) -> Result<{% if method.is_server_stream %}xidl_rust_axum::stream::SseStream<{{ method.response_ty }}>{% else %}{{ method.response_ty }}{% endif %}, xidl_rust_axum::Error>;
    {% endfor %}
}

{% for method in methods %}
    {% if method.path_params | length > 0 %}
        #[derive(::serde::Serialize, ::serde::Deserialize)]
        struct {{ method.struct_prefix }}Path {
            {% for param in method.path_params %}
                {% if param.serde_rename is defined and param.serde_rename %}
                    #[serde(rename = "{{ param.serde_rename }}")]
                {% endif %}
                {{ param.name }}: {{ param.ty }},
            {% endfor %}
        }

    {% endif %}
    {% if method.query_params | length > 0 %}
        #[derive(::serde::Serialize, ::serde::Deserialize)]
        struct {{ method.struct_prefix }}Query {
            {% for param in method.query_params %}
                {% if param.serde_rename is defined and param.serde_rename %}
                    #[serde(rename = "{{ param.serde_rename }}")]
                {% endif %}
                {{ param.name }}: {{ param.ty }},
            {% endfor %}
        }

    {% endif %}
    {% if method.body_params | length > 0 %}
        {% if method.body_params | length == 1 %}
            type {{ method.struct_prefix }}Body = {{ method.body_params[0].ty }};
        {% else %}
            #[derive(::serde::Serialize, ::serde::Deserialize)]
            struct {{ method.struct_prefix }}Body {
                {% for param in method.body_params %}
                    {% if param.serde_rename is defined and param.serde_rename %}
                        #[serde(rename = "{{ param.serde_rename }}")]
                    {% endif %}
                    {{ param.name }}: {{ param.ty }},
                {% endfor %}
            }
        {% endif %}

    {% endif %}
    {% if method.request_struct is defined and method.request_struct %}
        #[derive(::serde::Serialize, ::serde::Deserialize)]
        pub struct {{ method.request_struct }} {
            {% for param in method.request_params %}
                pub {{ param.name }}: {{ param.ty }},
            {% endfor %}
        }

    {% endif %}
    {% if method.response_struct is defined and method.response_struct %}
        #[derive(::serde::Serialize, ::serde::Deserialize)]
        pub struct {{ method.response_struct }} {
            {% if method.response_include_return %}
                pub r#return: {{ method.ret }},
            {% endif %}
            {% for param in method.response_params %}
                {% if param.serde_rename is defined and param.serde_rename %}
                    #[serde(rename = "{{ param.serde_rename }}")]
                {% endif %}
                pub {{ param.name }}: {{ param.ty }},
            {% endfor %}
        }

    {% endif %}
{% endfor %}

{% if opt.enable_server %}
    pub struct {{ ident }}Server<T> {
        inner: ::std::sync::Arc<T>,
    }

    impl<T> {{ ident }}Server<T>
    where
    T: {{ ident }} + Send + Sync + 'static,
    {
        pub fn new(inner: T) -> Self {
            Self {
                inner: ::std::sync::Arc::new(inner),
            }
        }

        pub fn from_arc(inner: ::std::sync::Arc<T>) -> Self {
            Self { inner }
        }

        pub fn router(self) -> xidl_rust_axum::axum::Router {
            let svc = self.inner;
            xidl_rust_axum::axum::Router::new()
            {% for method in methods %}
                {% for path in method.paths %}
                    .route("{{ path }}", xidl_rust_axum::axum::routing::{{ method.http_method_fn }}(Self::{{ method.name }}))
                {% endfor %}
            {% endfor %}
            .with_state(svc)
        }

        {% for method in methods %}
            async fn {{ method.name }}(
            ::xidl_rust_axum::axum::extract::State(svc): ::xidl_rust_axum::axum::extract::State<::std::sync::Arc<T>>,
            headers: ::xidl_rust_axum::axum::http::HeaderMap{% if method.path_params | length > 0 %},
            ::xidl_rust_axum::axum::extract::Path(path): ::xidl_rust_axum::axum::extract::Path<{{ method.struct_prefix }}Path>{% endif %}{% if method.query_params | length > 0 %},
            xidl_rust_axum::axum::extract::Query(query): xidl_rust_axum::axum::extract::Query<{{ method.struct_prefix }}Query>{% endif %}{% if method.is_client_stream %},
            body: ::xidl_rust_axum::axum::body::Body{% elif method.body_params | length > 0 %},
            xidl_rust_axum::axum::Json(body): xidl_rust_axum::axum::Json<{{ method.struct_prefix }}Body>{% endif %}
            ) -> ::xidl_rust_axum::Result<::xidl_rust_axum::axum::response::Response> {
                {% if method.path_params | length > 0 %}
                    let {{ method.struct_prefix }}Path {
                        {% for param in method.path_params %}
                            {{ param.name }},
                        {% endfor %}
                    } = path;
                {% endif %}
                {% if method.query_params | length > 0 %}
                    let {{ method.struct_prefix }}Query {
                        {% for param in method.query_params %}
                            {{ param.name }},
                        {% endfor %}
                    } = query;
                {% endif %}
                {% if method.body_params | length > 0 and not method.is_client_stream %}
                    {% if method.body_params | length == 1 %}
                        let {{ method.body_params[0].name }} = body;
                    {% else %}
                        let {{ method.struct_prefix }}Body {
                            {% for param in method.body_params %}
                                {{ param.name }},
                            {% endfor %}
                        } = body;
                    {% endif %}
                {% endif %}
                {% if method.is_client_stream %}
                    let data = xidl_rust_axum::stream::decode_ndjson_body::<{{ method.request_item_ty }}>(body);
                {% elif method.request_struct is defined and method.request_struct %}
                    let data = {{ method.request_struct }} {
                        {% for param in method.request_params %}
                            {{ param.name }},
                        {% endfor %}
                    };
                {% else %}
                    let data = ();
                {% endif %}
                let req = ::xidl_rust_axum::Request::new(headers, data);
                let resp = svc.{{ method.name }}(req).await?;
                {% if method.is_server_stream %}
                    Ok(xidl_rust_axum::stream::sse_response(resp))
                {% else %}
                    {% if method.response_is_empty %}
                        let _ = resp;
                        Ok(::xidl_rust_axum::axum::response::IntoResponse::into_response(::xidl_rust_axum::axum::http::StatusCode::NO_CONTENT))
                    {% else %}
                        Ok(::xidl_rust_axum::axum::response::IntoResponse::into_response(xidl_rust_axum::axum::Json(resp)))
                    {% endif %}
                {% endif %}
            }
        {% endfor %}
    }

    impl<T> xidl_rust_axum::Service for {{ ident }}Server<T>
    where
    T: {{ ident }} + Send + Sync + 'static,
    {
        fn into_router(self) -> xidl_rust_axum::axum::Router {
            self.router()
        }
    }
{% endif %}

{% if opt.enable_client %}
    pub struct {{ ident }}Client {
        client: xidl_rust_axum::Client,
    }

    impl {{ ident }}Client {
        pub fn new(base_url: impl Into<String>) -> Self {
            Self {
                client: xidl_rust_axum::Client::new(base_url),
            }
        }
    }

    impl {{ ident }}Client {
        {% for method in methods %}
            pub async fn {{ method.name }}(&self{% if method.params | length > 0 %}, {{ method.params | join(", ") }}{% endif %}) -> Result<{% if method.is_server_stream %}xidl_rust_axum::stream::SseClientStream<{{ method.response_ty }}>{% else %}{{ method.response_ty }}{% endif %}, xidl_rust_axum::Error> {
                let path = "{{ method.path }}".to_string();
                {% for param in method.path_params %}
                    let path = path.replace("{{ ['{', param.path_template_name, '}'] | join}}", &{{ param.name }}.to_string());
                {% endfor %}
                let url = self.client.url(&path);
                let mut req = self
                    .client
                    .http()
                    .request(xidl_rust_axum::reqwest::Method::{{ method.reqwest_method }}, url)
                    .build()
                    .map_err(|err| xidl_rust_axum::Error::new(500, err.to_string()))?;
                {% if method.query_params | length > 0 %}
                    let query = {{ method.struct_prefix }}Query {
                        {% for param in method.query_params %}
                            {{ param.name }},
                        {% endfor %}
                    };
                    let query = xidl_rust_axum::serde_urlencoded::to_string(&query)
                        .map_err(|err| xidl_rust_axum::Error::new(500, err.to_string()))?;
                    if !query.is_empty() {
                        req.url_mut().set_query(Some(&query));
                    }
                {% endif %}
                {% if method.is_client_stream %}
                    req.headers_mut().insert(
                        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
                        xidl_rust_axum::reqwest::header::HeaderValue::from_static("application/x-ndjson"),
                    );
                    *req.body_mut() = Some(xidl_rust_axum::stream::encode_ndjson_body(stream));
                {% elif method.body_params | length > 0 %}
                    {% if method.body_params | length == 1 %}
                        let body = {{ method.body_params[0].name }};
                    {% else %}
                        let body = {{ method.struct_prefix }}Body {
                            {% for param in method.body_params %}
                            {{ param.name }},
                            {% endfor %}
                        };
                    {% endif %}
                    let body = xidl_rust_axum::serde_json::to_vec(&body)
                        .map_err(|err| xidl_rust_axum::Error::new(500, err.to_string()))?;
                    req.headers_mut().insert(
                        xidl_rust_axum::reqwest::header::CONTENT_TYPE,
                        xidl_rust_axum::reqwest::header::HeaderValue::from_static("application/json"),
                    );
                    *req.body_mut() = Some(xidl_rust_axum::reqwest::Body::from(body));
                {% endif %}
                {% if method.is_server_stream %}
                    xidl_rust_axum::stream::open_sse::<{{ method.response_ty }}>(self.client.http(), req).await
                {% else %}
                let resp = self
                    .client
                    .http()
                    .execute(req)
                    .await
                    .map_err(|err| xidl_rust_axum::Error::new(500, err.to_string()))?;
                if resp.status().is_success() {
                    {% if method.response_is_empty %}
                        Ok(())
                    {% else %}
                        resp.json::<{{ method.response_ty }}>()
                        .await
                        .map_err(|err| xidl_rust_axum::Error::new(500, err.to_string()))
                    {% endif %}
                } else {
                    let status = resp.status();
                    let body = resp.json::<xidl_rust_axum::ErrorBody>().await.ok();
                    let err = match body {
                        Some(body) => xidl_rust_axum::Error::new(body.code, body.msg),
                        None => xidl_rust_axum::Error::new(500, format!("http error: {}", status.as_u16())),
                    };
                    Err(err)
                }
                {% endif %}
            }
        {% endfor %}
    }
{% endif %}
