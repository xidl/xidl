XcdrBufferResult {{ ident }}_serialize({{ ident }} const* self, XcdrBuffer buf) {
    uint8_t *ptr = buf.ptr;
    size_t len = buf.len;
    FfiCdrSerializer serializer = cdr_serializer_new(ptr, len);
    XcdrFfiError err = Ok;
    {% if xcdr_fields | length == 0 %}
        (void)self;
    {% else %}
        {% for field in xcdr_fields %}
            {% set ns = namespace(expr=field.expr) %}
                {% for dim in field.dims %}
                    for (size_t i{{ loop.index0 }} = 0; i{{ loop.index0 }} < {{ dim }}; ++i{{ loop.index0 }}) {{ "{" }}
                    {% set ns.expr = ns.expr ~ "[i" ~ loop.index0 ~ "]" %}
                    {% endfor %}
                    {% if field.kind.kind == "primitive" %}
                        err = {{ field.kind.serialize_fn }}(&serializer, "{{ ns.expr }}");
                        if (err != Ok) {
                            return (XcdrBufferResult){ err, cdr_serializer_position(&serializer) };
                        }
                    {% elif field.kind.kind == "custom" %}
                        {
                            size_t before = cdr_serializer_position(&serializer);
                            XcdrBufferResult child = {{ field.kind.type_name }}_serialize(
                            &{{ ns.expr }},
                            (XcdrBuffer){ .ptr = ptr + before, .len = len - before, .pos = 0 });
                            if (child.err != Ok) {
                                return (XcdrBufferResult){ child.err, before + child.used };
                            }
                            serializer.pos = before + child.used;
                        }
                    {% else %}
                        /* {{ field.kind.reason }} */
                    {% endif %}
                    {% for dim in field.dims | reverse %}
                    }
                {% endfor %}
            {% endfor %}
        {% endif %}
        return (XcdrBufferResult){ Ok, cdr_serializer_position(&serializer) };
        }

