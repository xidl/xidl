            XcdrFfiError err = Ok;
            {% if xcdr_fields | length == 0 %}
                (void)self;
            {% else %}
                {% for field in xcdr_fields %}
                    {% set ns = namespace(expr=field.expr) %}
                        {% for dim in field.dims %}
                            for (size_t i{{ loop.index0 }} = 0; i{{ loop.index0 }} < {{ dim }}; ++i{{ loop.index0 }}) {{ "{" }}
                            {% set ns.expr = ns.expr ~ "[i" ~ loop.index0 ~ "]" %}
                            {% endfor %}
                            {% if field.kind.kind == "primitive" %}
                                err = {{ field.kind.deserialize_fn }}(&deserializer, "{{ ns.expr }}");
                                if (err != Ok) {
                                    return (XcdrBufferResult){ err, cdr_deserializer_position(&deserializer) };
                                }
                            {% elif field.kind.kind == "custom" %}
                                {
                                    size_t before = cdr_deserializer_position(&deserializer);
                                    XcdrBufferResult child = {{ field.kind.type_name }}_deserialize(
                                    &{{ ns.expr }},
                                    (XcdrConstBuffer){ .ptr = ptr + before, .len = len - before, .pos = 0 });
                                    if (child.err != Ok) {
                                        return (XcdrBufferResult){ child.err, before + child.used };
                                    }
                                    deserializer.pos = before + child.used;
                                }
                            {% else %}
                                /* {{ field.kind.reason }} */
                            {% endif %}
                            {% for dim in field.dims | reverse %}
                            }
                        {% endfor %}
                    {% endfor %}
                {% endif %}
                return (XcdrBufferResult){ Ok, cdr_deserializer_position(&deserializer) };
                }