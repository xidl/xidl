        // Code generated by xidlc-v{{ opt.xidlc_version }}-{{ opt.xidlc_shorthash }}. DO NOT EDIT.
    {% endif %}
    import type * as types from "./{{ file_stem }}";
    import type * as ifaceTypes from "./{{ file_stem }}.iface";
    import * as ifaceSchemas from "./{{ file_stem }}.iface.zod";
    {% for helper in helpers %}
        {{ helper }}
    {% endfor %}
    {% for block in blocks %}
        {{ block }}
    {% endfor %}
{% endfilter %}
