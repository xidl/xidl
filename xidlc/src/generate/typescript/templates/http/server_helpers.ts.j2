import { serialize, deserialize } from "xidl-typescript-codec";
import { z } from "zod";

type Awaitable<T> = T | Promise<T>;
export type ServerHandler = (request: Request) => Promise<Response>;
export interface HttpCodec {
    encode?: (value: unknown, schema?: z.ZodTypeAny) => BodyInit | null;
    decode?: <T>(resp: Response, schema?: z.ZodTypeAny) => Promise<T>;
}

type SecurityRequirement = {
    kind: string;
    location?: string;
    name?: string;
    realm?: string;
    scopes: string[];
};

type RouteSpec = {
    method: string;
    path: string;
    handler: (request: Request, params: Record<string, string>) => Promise<Response>;
};

type ResponseFieldSpec = {
    name: string;
    key: string;
    isMulti?: boolean;
};

export interface ServerOptions {
    codecs?: Record<string, HttpCodec>;
    authorize?: (
    request: Request,
    requirements: SecurityRequirement[],
    ) => Awaitable<void>;
    onError?: (error: unknown) => Awaitable<Response>;
}

export class XidlServerError extends Error {
    readonly status: number;
    readonly code: number;
    readonly headers?: Record<string, string>;

    constructor(message: string, status = 500, code = status, headers?: Record<string, string>) {
        super(message);
        this.status = status;
        this.code = code;
        this.headers = headers;
    }
}

function createRouter(
routes: RouteSpec[],
options: ServerOptions,
): ServerHandler {
    return async (request) => {
        try {
            const url = new URL(request.url);
            let pathMatched = false;
            for (const route of routes) {
                const params = matchRoute(route.path, url.pathname);
                if (params) {
                    pathMatched = true;
                    if (route.method === request.method.toUpperCase()) {
                        return await route.handler(request, params);
                    }
                }
            }
            if (pathMatched) {
                const allowed = routes
                .filter((r) => matchRoute(r.path, url.pathname))
                .map((r) => r.method);
                return new Response(JSON.stringify({ code: 405, msg: "Method Not Allowed" }), {
                    status: 405,
                    headers: {
                        "Content-Type": "application/json",
                        "Allow": Array.from(new Set(allowed)).join(", "),
                    },
                });
            }

            return new Response(JSON.stringify({ code: 404, msg: "Not Found" }), {
                status: 404,
                headers: { "Content-Type": "application/json" },
            });
        } catch (error) {
            if (options.onError) {
                return await options.onError(error);
            }
            return errorResponse(error);
        }

    };
}

async function authorizeRequest(
request: Request,
requirements: SecurityRequirement[],
options: ServerOptions,
): Promise<void> {
    if (requirements.length === 0 || !options.authorize) {
        return;
    }
    await options.authorize(request, requirements);
}

function matchRoute(pattern: string, pathname: string): Record<string, string> | null {
    const left = pattern.split("/").filter(Boolean);
    const right = pathname.split("/").filter(Boolean);
    const params: Record<string, string> = {};
    let index = 0;
    for (; index < left.length; index += 1) {
        const part = left[index];
        const value = right[index];
        if (!part) {
            continue;
        }
        if (part.startsWith("{*") && part.endsWith("}")) {
            params[part.slice(2, -1)] = decodeURIComponent(right.slice(index).join("/"));
            return params;
        }
        if (value === undefined) {
            return null;
        }
        if (part.startsWith("{") && part.endsWith("}")) {
            params[part.slice(1, -1)] = decodeURIComponent(value);
            continue;
        }
        if (part !== value) {
            return null;
        }
    }
    return index === right.length ? params : null;
}

function readPathParam(params: Record<string, string>, name: string): unknown {
    return parseScalar(params[name] ?? "");
}

function readQueryParam(query: URLSearchParams, name: string, isMulti: boolean): unknown {
    const values = query.getAll(name);
    if (values.length === 0) {
        return isMulti ? [] : undefined;
    }
    return isMulti ? values.map(parseScalar) : parseScalar(values[0] as string);
}

function readHeaderParam(headers: Headers, name: string, isMulti: boolean): unknown {
    const value = headers.get(name);
    if (value === null) {
        return isMulti ? [] : undefined;
    }
    return isMulti ? value.split(",").map((item) => parseScalar(item.trim())) : parseScalar(value);
}

function readCookieParam(headers: Headers, name: string, isMulti: boolean): unknown {
    const values = readRequestCookies(headers).get(name);
    if (!values || values.length === 0) {
        return isMulti ? [] : undefined;
    }
    return isMulti ? values.map(parseScalar) : parseScalar(values[0] as string);
}

function readRequestCookies(headers: Headers): Map<string, string[]> {
    const out = new Map<string, string[]>();
    const raw = headers.get("Cookie");
    if (!raw) {
        return out;
    }
    for (const part of raw.split(";")) {
        const item = part.trim();
        if (!item) {
            continue;
        }
        const idx = item.indexOf("=");
        if (idx < 0) {
            continue;
        }
        const key = item.slice(0, idx).trim();
        const value = decodeURIComponent(item.slice(idx + 1));
        const current = out.get(key) ?? [];
        current.push(value);
        out.set(key, current);
    }
    return out;
}

async function decodeRequestBody(
request: Request,
contentType: string,
codecs: Record<string, HttpCodec>,
schema?: z.ZodTypeAny,
): Promise<unknown> {
    const mime = normalizeMime(contentType || request.headers.get("Content-Type") || "application/json");
    const custom = codecs[mime]?.decode;
    if (custom) {
        const response = new Response(request.body, { headers: request.headers });
        return custom(response, schema);
    }
    if (mime === "application/json" || mime.endsWith("+json") || mime === "application/msgpack") {
        const data = await request.json();
        return schema ? deserialize(data, schema) : data;
    }

    if (mime === "application/x-www-form-urlencoded") {
        const form = new URLSearchParams(await request.text());
        const out: Record<string, unknown> = {};
        for (const key of new Set(form.keys())) {
            const values = form.getAll(key);
            out[key] = values.length > 1 ? values.map(parseScalar) : parseScalar(values[0] as string);
        }
        return out;
    }
    if (mime.startsWith("text/")) {
        return parseScalar(await request.text());
    }
    throw new XidlServerError(`unsupported request content type: ${mime}`, 415);
}

function applyRequestBody(
target: Record<string, unknown>,
body: unknown,
singleKey: string | undefined,
bodyFields: string[],
): void {
    if (singleKey) {
        target[singleKey] = body;
        return;
    }
    if (!body || typeof body !== "object" || Array.isArray(body)) {
        return;
    }
    for (const field of bodyFields) {
        if (field in body) {
            target[field] = (body as Record<string, unknown>)[field];
        }
    }
}

async function* ndjsonRequestStream<T>(request: Request, schema?: z.ZodTypeAny): AsyncIterable<T> {
    if (!request.body) {
        return;
    }
    const reader = request.body.getReader();
    const decoder = new TextDecoder();
    let buffer = "";
    while (true) {
        const next = await reader.read();
        if (next.done) {
            break;
        }
        buffer += decoder.decode(next.value, { stream: true });
        while (true) {
            const idx = buffer.indexOf("\n");
            if (idx < 0) {
                break;
            }
            const line = buffer.slice(0, idx).trim();
            buffer = buffer.slice(idx + 1);
            if (line) {
                const data = JSON.parse(line);
                yield (schema ? deserialize(data, schema) : data) as T;
            }
        }
    }
}

function sseResponse<T>(
source: AsyncIterable<T>,
options: ServerOptions,
schema?: z.ZodTypeAny,
): Response {
    void options;
    const encoder = new TextEncoder();
    return new Response(
    new ReadableStream<Uint8Array>({
        async start(controller) {
            for await (const item of source) {
                const serialized = schema ? serialize(item, schema) : item;
                controller.enqueue(encoder.encode("event: next\ndata: " + JSON.stringify(serialized) + "\n\n"));
            }
            controller.enqueue(encoder.encode("event: complete\ndata: done\n\n"));
            controller.close();
        },
    }),
    { headers: { "Content-Type": "text/event-stream" } },
    );
}

function encodeServerResponse(
value: unknown,
contentType: string,
bodyMode: string,
bodyFields: ResponseFieldSpec[],
headerFields: ResponseFieldSpec[],
cookieFields: ResponseFieldSpec[],
codecs: Record<string, HttpCodec>,
schema?: z.ZodTypeAny,
): Response {
    const headers = new Headers();
    const serialized = schema ? serialize(value, schema) : value;
    const payload = serialized && typeof serialized === "object" ? (serialized as Record<string, unknown>) : {};
    for (const field of headerFields) {
        writeHeader(headers, field.name, payload[field.name], field.isMulti ?? false);
    }
    for (const field of cookieFields) {
        writeCookie(headers, field.name, payload[field.name], field.isMulti ?? false);
    }
    if (bodyMode === "none") {
        return new Response(null, { status: 204, headers });
    }
    const body =
    bodyMode === "return"
    ? bodyFields[0]?.name === "return"
    ? payload["return"] ?? serialized
    : payload[bodyFields[0]?.name ?? "return"]
    : Object.fromEntries(
    bodyFields.map((field) => [field.name, payload[field.name]]).filter((entry) => entry[1] !== undefined),
    );
    headers.set("Content-Type", contentType);
    return new Response(encodeBody(body, contentType, codecs), { status: 200, headers });
}

function writeHeader(headers: Headers, name: string, value: unknown, isMulti: boolean): void {
    if (value === undefined || value === null) {
        return;
    }
    if (isMulti && Array.isArray(value)) {
        for (const item of value) {
            headers.append(name, encodeScalar(item));
        }
        return;
    }
    headers.set(name, encodeScalar(value));
}

function writeCookie(headers: Headers, name: string, value: unknown, isMulti: boolean): void {
    if (value === undefined || value === null) {
        return;
    }
    const items = isMulti && Array.isArray(value) ? value : [value];
    for (const item of items) {
        headers.append("Set-Cookie", `${name}=${encodeURIComponent(encodeScalar(item))}`);
    }
}

function encodeBody(
value: unknown,
contentType: string,
codecs: Record<string, HttpCodec>,
schema?: z.ZodTypeAny,
): BodyInit | null {
    const mime = normalizeMime(contentType);
    const custom = codecs[mime]?.encode;
    if (custom) {
        return custom(value, schema);
    }
    if (mime === "application/json" || mime.endsWith("+json") || mime === "application/msgpack") {
        const serialized = schema ? serialize(value, schema) : value;
        return JSON.stringify(serialized);
    }

    if (mime.startsWith("text/")) {
        return String(value ?? "");
    }
    throw new XidlServerError(`unsupported response content type: ${mime}`, 500);
}

function normalizeMime(value: string): string {
    return value.split(";")[0]?.trim().toLowerCase() ?? "application/json";
}

function encodeScalar(value: unknown): string {
    if (typeof value === "string" || typeof value === "number" || typeof value === "boolean") {
        return String(value);
    }
    return JSON.stringify(value);
}

function parseScalar(value: string): unknown {
    if (value === "true") {
        return true;
    }
    if (value === "false") {
        return false;
    }
    if (/^-?\d+(\.\d+)?$/.test(value)) {
        return Number(value);
    }
    try {
        return JSON.parse(value);
    } catch {
        return value;
    }
}

function errorResponse(error: unknown): Response {
    if (error instanceof XidlServerError) {
        const headers = new Headers({ "Content-Type": "application/json" });
        if (error.headers) {
            for (const [key, value] of Object.entries(error.headers)) {
                headers.set(key, value);
            }
        }
        return new Response(JSON.stringify({ code: error.code, msg: error.message }), {
            status: error.status,
            headers,
        });
    }
    if (error && typeof error === "object" && "name" in error && error.name === "ZodError") {
        return new Response(JSON.stringify({ code: 400, msg: "validation failed", detail: (error as any).errors }), {
            status: 400,
            headers: { "Content-Type": "application/json" },
        });
    }
    const message = error instanceof Error ? error.message : "internal server error";
    return new Response(JSON.stringify({ code: 500, msg: message }), {
        status: 500,
        headers: { "Content-Type": "application/json" },
    });
}
