{% filter tsfmt %}
    {% if opt.enable_metadata %}
        // Code generated by xidlc-v{{ opt.xidlc_version }}-{{ opt.xidlc_shorthash }}. DO NOT EDIT.
    {% endif %}
    import { z } from "zod";
    {% if imports and imports | length > 0 %}
        import { {{ imports | join(", ") }} } from "./{{ file_stem }}.zod";
    {% endif %}
    {% for block in blocks %}
        {{ block }}
    {% endfor %}
{% endfilter %}
