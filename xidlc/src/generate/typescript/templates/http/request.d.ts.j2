{% from "macros.j2" import render_type %}
{% if doc and doc | length > 0 %}
    /**
    {% for line in doc %} * {{ line }}
    {% endfor %} */
{% endif %}
export interface {{ name }} {
    {% for param in params %}{% if param.doc and param.doc | length > 0 %}
        /**
        {% for line in param.doc %}     * {{ line }}
        {% endfor %}     */
        {% endif %}    {{ param.prop }}{% if param.optional %}?{% endif %}: {{ render_type(param.ty) }};
        {% endfor %}}
