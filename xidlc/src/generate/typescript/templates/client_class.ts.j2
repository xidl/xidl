{% from "macros.j2" import render_type, render_zod %}
export class {{ client_name }}Client {
    private readonly baseUrl: string;
    private readonly fetchImpl: FetchLike;
    private readonly defaultHeaders: Record<string, string>;

    constructor(baseUrl: string, options: ClientOptions = {}) {
        this.baseUrl = baseUrl;
        this.fetchImpl = resolveFetch(options.fetch);
        this.defaultHeaders = options.headers ?? {};
    }
    {% for method in methods %}
        {% if method.doc and method.doc | length > 0 %}
            /**
            {% for line in method.doc %} * {{ line }}
            {% endfor %} */
        {% endif %}
        {% if method.is_server_stream %}{{ method.name }}{% else %}async {{ method.name }}{% endif %}({% for param in method.params %}{{ param.name }}: {{ render_type(param.ty) }}{% if not loop.last %}, {% endif %}{% endfor %}): {% if method.is_server_stream %}{{ render_type(method.return_ty) }}{% else %}Promise<{{ render_type(method.return_ty) }}>{% endif %} {
            {% if method.request_schema_ref and not method.is_client_stream %}        const payload = { {% for entry in method.request_payload %}"{{ entry.raw_name }}": {{ entry.name }}{% if not loop.last %}, {% endif %}{% endfor %} };
            const parsed = zodSchemas.{{ method.request_schema_ref }}Schema.parse(payload);
            {% endif %}        let path = "{{ method.path }}";
            {% for param in method.path_params %}        path = path.replace("{" + "{{ param.template_name }}" + "}", {% if param.catch_all %}encodePathCatchAll{% else %}encodePathSegment{% endif %}({{ param.access }}));
        {% endfor %}{% if method.query_params | length > 0 %}
        const query = new URLSearchParams();
        {% for param in method.query_params %}        query.set("{{ param.raw_name }}", encodeQueryValue({{ param.access }}));
        {% endfor %}        const queryString = query.toString();
        if (queryString.length > 0) {
            path = `${path}?${queryString}`;
        }
        {% endif %}{% if method.body_params | length > 0 %}
        {% if method.body_params | length == 1 %}
            const body = {{ method.body_single.access }};
        {% else %}
            const body = {
                {% for param in method.body_params %}            "{{ param.raw_name }}": {{ param.access }},
                {% endfor %}        };
        {% endif %}
        {% endif %}        const headers = new Headers(this.defaultHeaders);
        {% for param in method.header_params %}        {% if param.is_multi %}for (const value of {{ param.access }}) {
            headers.append("{{ param.raw_name }}", encodeHeaderValue(value));
        }
        {% else %}headers.set("{{ param.raw_name }}", encodeHeaderValue({{ param.access }}));
        {% endif %}{% endfor %}
        {% if method.cookie_params | length > 0 %}
            const cookiePairs: string[] = [];
            {% for param in method.cookie_params %}        {% if param.is_multi %}for (const value of {{ param.access }}) {
                cookiePairs.push(`${"{{ param.raw_name }}"}=${encodeCookieValue(value)}`);
            }
            {% else %}cookiePairs.push(`${"{{ param.raw_name }}"}=${encodeCookieValue({{ param.access }})}`);
            {% endif %}{% endfor %}        if (cookiePairs.length > 0) {
                const cookieValue = cookiePairs.join("; ");
                const existing = headers.get("Cookie");
                headers.set("Cookie", existing ? `${existing}; ${cookieValue}` : cookieValue);
            }
        {% endif %}
        {% if method.body_params | length > 0 %}
            headers.set("Content-Type", "application/json");
            const serializedBody = serialize(body, zodSchemas.{{ method.body_schema_ref }}Schema);
            const options = { method: "{{ method.http_method }}", headers, body: JSON.stringify(serializedBody) };
        {% else %}
            const options = { method: "{{ method.http_method }}", headers };
        {% endif %}
        const url = joinUrl(this.baseUrl, path);
        {% if method.is_server_stream %}
            const itemSchema = zodSchemas.{{ method.return_schema_ref }}Schema;
            return sseJsonStream<{{ render_type(method.stream_item_ty) }}>(this.fetchImpl, url, options, itemSchema);
        {% elif method.is_client_stream %}
            headers.set("Content-Type", "application/x-ndjson");
            const itemSchema = zodSchemas.{{ method.request_schema_ref }}Schema;
            const streamBody = ndjsonBody<{{ render_type(method.client_stream_item_ty) }}>(stream, itemSchema);
            const resp = await this.fetchImpl(url, { method: "{{ method.http_method }}", headers, body: streamBody });
            if (!resp.ok) {
                throw await parseXidlError(resp);
            }
            {% if method.return_ty.kind == "Void" %}        return;
            {% else %}        const data = await resp.json();
            {% if method.return_schema_ref %}        return deserialize(data, zodSchemas.{{ method.return_schema_ref }}Schema) as {{ render_type(method.return_ty) }};
            {% else %}        return data as {{ render_type(method.return_ty) }};
        {% endif %}        {% endif %}
        {% else %}
            const resp = await this.fetchImpl(url, options);
            if (!resp.ok) {
                throw await parseXidlError(resp);
            }
            {% if method.return_ty.kind == "Void" %}        return;
            {% else %}        const data = await resp.json();
            {% if method.return_schema_ref %}        return deserialize(data, zodSchemas.{{ method.return_schema_ref }}Schema) as {{ render_type(method.return_ty) }};
            {% else %}        return data as {{ render_type(method.return_ty) }};
        {% endif %}        {% endif %}
        {% endif %}    }
    {% endfor %}}
