{%- if method.response_header_encode %}
    {{ method.response_header_encode | indent(1, true) }}
{%- endif %}
{%- if method.response_cookie_encode %}
    {{ method.response_cookie_encode | indent(1, true) }}
{%- endif %}
{%- if method.response_body_struct %}
    respBody := {{ method.response_body_struct }}{
        {%- if method.return_ty %}
            Return: {{ value }}.Return,
        {%- endif %}
        {%- for param in method.response_body_params %}
            {{ param.field_name }}: {{ value }}.{{ param.field_name }},
        {%- endfor %}
    }
    if err := xidlgohttp.GinEncodeBody(c, "{{ method.response_content_type }}", respBody); err != nil {
        xidlgohttp.GinWriteJSONError(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())
    }
{%- elif method.response_body_direct_field %}
    if err := xidlgohttp.GinEncodeBody(c, "{{ method.response_content_type }}", {{ value }}.{{ method.response_body_direct_field }}); err != nil {
        xidlgohttp.GinWriteJSONError(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())
    }
{%- else %}
    c.Status(http.StatusNoContent)
{%- endif %}
