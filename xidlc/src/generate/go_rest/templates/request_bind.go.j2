{%- if optional and ty == "string" %}
    {%- if source_kind == "Query" %}
        {{ field }} = xidlgohttp.QueryOptionalString(c.Request.URL.Query(), "{{ wire_name }}")
    {%- elif source_kind == "Header" %}
        {{ field }} = xidlgohttp.ParseOptionalString(c.Request.Header.Get("{{ wire_name }}"))
    {%- elif source_kind == "Cookie" %}
        if cookie, err := c.Cookie("{{ wire_name }}"); err == nil {
            {{ field }} = &cookie
        }
    {%- endif %}
{%- elif optional and ty == "uint32" %}
    if raw, err := {{ call }}; err == nil {
        if value, parseErr := xidlgohttp.ParseUint32(raw); parseErr == nil { {{ field }} = &value } else {
            xidlgohttp.GinWriteJSONError(c, http.StatusBadRequest, http.StatusBadRequest, parseErr.Error())
            return
        }
    }
