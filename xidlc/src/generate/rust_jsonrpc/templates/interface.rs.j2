#[async_trait::async_trait]
impl<R, W> {{ ident }} for {{ ident }}Client<R, W>
where
R: tokio::io::AsyncRead + Unpin + Send + 'static,
    W: tokio::io::AsyncWrite + Unpin + Send + 'static,
{
    {% for method in methods %}
        {% if method.kind == "rpc" %}
            async fn {{ method.name }}(& self{% if method.params | length > 0 %}, {{ method.params | join(", ") }}{% endif %}) -> Result<{{ method.ret }}, xidl_jsonrpc::Error> {
                let params = {{ method.params_struct }} {
                    {% for field in method.params_fields %}
                        {{ field.name }},
                    {% endfor %}
                };

                let mut client = self.client.lock().await;
                {% if method.response_kind == "empty" %}
                    let _: ::serde_json::Value = client.call("{{ method.rpc_name }}", params).await?;
                    Ok(())
                {% elif method.response_kind == "single_return" or method.response_kind == "single_output" %}
                    let result: {{ method.response_struct }} = client.call("{{ method.rpc_name }}", params).await?;
                    Ok(result.{{ method.response_single_field }})
                {% else %}
                    client.call("{{ method.rpc_name }}", params).await
                {% endif %}
            }
        {% elif method.kind == "stream_op" and method.stream_mode == "client" %}
            async fn {{ method.name }}<'a>(&'a self, mut stream: xidl_jsonrpc::stream::BoxStream<'a, serde_json::Value>) -> Result<{{ method.ret }}, xidl_jsonrpc::Error> {
                let mut items = Vec::<::serde_json::Value>::new();
                while let Some(item) = xidl_jsonrpc::futures_util::StreamExt::next(&mut stream).await {
                    items.push(item?);
                }
                let mut client = self.client.lock().await;
                {% if method.response_kind == "empty" %}
                    let _: ::serde_json::Value = client.call("{{ method.rpc_name }}", items).await?;
                    Ok(())
                {% elif method.response_kind == "single_return" or method.response_kind == "single_output" %}
                    let result: {{ method.response_struct }} = client.call("{{ method.rpc_name }}", items).await?;
                    Ok(result.{{ method.response_single_field }})
                {% else %}
                    client.call("{{ method.rpc_name }}", items).await
                {% endif %}
            }
        {% elif method.kind == "stream_source" %}
            async fn {{ method.name }}(& self) -> Result<xidl_jsonrpc::stream::BoxStream<'_, {{ method.stream_item_ty }}>, xidl_jsonrpc::Error> {
                Err(xidl_jsonrpc::Error::Protocol("stream source method is server-side only"))
            }
        {% elif method.kind == "stream_op" %}
            async fn {{ method.name }}<'a>(&'a self{% if method.params | length > 0 %}, {{ method.params | join(", ") }}{% endif %}) -> Result<{{ method.ret }}, xidl_jsonrpc::Error> {
                Err(xidl_jsonrpc::Error::Protocol("stream operation is not implemented in client runtime"))
            }
        {% endif %}
    {% endfor %}
}

impl<R, W> {{ ident }}Client<R, W>
where
R: tokio::io::AsyncRead + Unpin + Send + 'static,
W: tokio::io::AsyncWrite + Unpin + Send + 'static,
{
    {% for method in watch_methods %}
        pub async fn {{ method.getter_name }}(&self) -> Result<xidl_jsonrpc::stream::BoxStream<'_, {{ method.item_ty }}>, xidl_jsonrpc::Error> {
            let value = <Self as {{ ident }}>::{{ method.getter_name }}(self).await?;
            let stream = async_stream::try_stream! {
                yield value;
            };
            Ok(xidl_jsonrpc::stream::boxed(stream))
        }
    {% endfor %}
    {% for method in methods %}
        {% if method.kind == "stream_op" and method.stream_mode == "client" %}
            pub async fn {{ method.name }}(&self) -> Result<xidl_jsonrpc::stream::ClientStreamWriter<serde_json::Value, {{ method.ret }}>, xidl_jsonrpc::Error> {
                let (tx, mut rx) = tokio::sync::mpsc::channel(32);
                let client = self.client.clone();
                let response = tokio::spawn(async move {
                    let mut items = Vec::<::serde_json::Value>::new();
                    while let Some(item) = rx.recv().await {
                        items.push(item?);
                    }
                    let mut client = client.lock().await;
                    {% if method.response_kind == "empty" %}
                        let _: ::serde_json::Value = client.call("{{ method.rpc_name }}", items).await?;
                        Ok(())
                    {% elif method.response_kind == "single_return" or method.response_kind == "single_output" %}
                        let result: {{ method.response_struct }} = client.call("{{ method.rpc_name }}", items).await?;
                        Ok(result.{{ method.response_single_field }})
                    {% else %}
                        client.call("{{ method.rpc_name }}", items).await
                    {% endif %}
                });
                Ok(xidl_jsonrpc::stream::ClientStreamWriter::new(tx, response))
            }
        {% endif %}
    {% endfor %}
}
