@http_basic
@api_key(in = "header", name = "X-Org-Key")
interface HttpSecurityApi {
    @get(path = "/reports/{id}")
    string get_report(
        @path("id")
        string id,
        @header("X-Trace-Id")
        string trace_id
    );
    @oauth2(scopes = "reports:write")
    @post(path = "/reports/{id}")
    string update_report(
        @path("id")
        string id,
        string body
    );
    @no_security
    @get(path = "/health")
    string health();
};

